    "test:docs-handbook-local": "node scripts/verify-docs-handbook-local.cjs",
    "test:mobile-optimization": "node scripts/verify-mobile-optimization-contract.cjs",
    "test:layout-smoke": "npm run test:html-assemble && npm run test:clients && npm run test:home-cases && npm run test:case-all && npm run test:blog && npm run test:floating-cta && npm run test:nginx-compression && npm run test:snapshot-prefix && npm run test:docs-handbook-local && npm run test:mobile-optimization && npm run test:semantic-core && npm run verify:meta-description",
