{
  "name": "serenity",
  "private": true,
  "description": "Static home snapshot; dev tools for layout tests",
  "scripts": {
    "build:cases": "node scripts/build-cases-all-data.mjs && node scripts/build-case-all-pages.mjs && node scripts/build-case-mobile-media.mjs",
    "build:html": "npm run build:cases && node scripts/assemble-html.cjs build && node scripts/typography-nbsp.cjs",
    "dev": "node scripts/dev-server.cjs",
    "test:clients": "node scripts/verify-clients.cjs",
    "test:home-cases": "node scripts/verify-home-cases.cjs",
    "test:case-all": "node scripts/verify-case-all.cjs",
    "test:case-all-visual": "node scripts/verify-case-all-visual-parity.cjs",
    "test:menu": "node scripts/verify-menu-screen.cjs",
    "test:leave-cta": "node scripts/verify-leave-request-cta.cjs",
    "test:sliders": "node scripts/slider-smoke.cjs",
    "test:lead-api": "node scripts/verify-lead-api.mjs",
    "test:routing-config": "node scripts/verify-routing-config.cjs",
    "test:nginx-compression": "node scripts/verify-nginx-compression-config.cjs",
    "test:floating-cta": "node scripts/verify-floating-cta.cjs",
    "test:html-assemble": "node scripts/verify-html-assemble.cjs",
    "test:typography-nbsp": "node scripts/verify-typography-nbsp.cjs",
    "typography:nbsp": "node scripts/typography-nbsp.cjs",
    "test:layout-smoke": "npm run test:html-assemble && npm run test:clients && npm run test:home-cases && npm run test:case-all && npm run test:floating-cta && npm run test:nginx-compression",
    "measure:rhythm": "node scripts/home-rhythm-measure.cjs",
    "test:services-blog-gap": "node scripts/verify-services-blog-card-gap.cjs",
    "test:readability-slow": "node scripts/verify-readability-slow-network.cjs",
    "test:hero-poster": "node scripts/verify-hero-video-poster.cjs",
    "capture:form-parity": "node scripts/generate-form-50-50-overlay.cjs"
  },
  "devDependencies": {
    "playwright": "^1.50.0",
    "sharp": "^0.34.5"
  }
}
