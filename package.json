    "test:services-blog-gap": "node scripts/verify-services-blog-card-gap.cjs",
    "test:readability-slow": "node scripts/verify-readability-slow-network.cjs",
    "test:hero-poster": "node scripts/verify-hero-video-poster.cjs",
    "test:post-deploy-smoke": "node scripts/post-deploy-smoke.cjs",
    "capture:form-parity": "node scripts/generate-form-50-50-overlay.cjs"
