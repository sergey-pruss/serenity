  "devDependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "googleapis": "^144.0.0",
    "iconv-lite": "^0.7.2",
    "playwright": "^1.50.0",
    "read-excel-file": "^9.0.9",
    "sharp": "^0.34.5"
  }
