# /etc/nginx/sites-available/serenity.agency
#
# Example production vhost for progressive migration:
# - NEW pages are served from local static root
# - all other pages are proxied to LEGACY origin

# Прокси на legacy по HTTPS (порт 443), иначе WordPress отвечает 301 на https://serenity.agency/... и циклит на edge.
upstream serenity_legacy_origin {
    server 80.78.246.207:443;
    keepalive 16;
}

server {
    listen 80;
    listen [::]:80;
    server_name serenity.agency;

    return 301 https://serenity.agency$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.serenity.agency;

    # Set real certificate paths on host
    ssl_certificate     /etc/letsencrypt/live/serenity.agency/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/serenity.agency/privkey.pem;

    return 301 https://serenity.agency$request_uri;
}

server {
    listen 80;
    listen [::]:80;
    server_name www.serenity.agency;

    return 301 https://serenity.agency$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name serenity.agency;

    # Set real certificate paths on host
    ssl_certificate     /etc/letsencrypt/live/serenity.agency/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/serenity.agency/privkey.pem;

    root /var/www/static;
    index index.html;

    # Текстовые ответы: gzip по запросу клиента (Accept-Encoding). Файлы на диске не меняются.
    gzip on;
    gzip_vary on;
    gzip_min_length 256;
    gzip_comp_level 5;
    gzip_http_version 1.1;
    gzip_proxied any;
    # MIME главной страницы в списке не дублируем — иначе nginx предупреждает о повторе типа (дефолт от gzip в http{}).
    gzip_types
        text/plain
        text/css
        text/xml
        application/javascript
        application/json
        application/xml
        application/rss+xml
        image/svg+xml;

    # Основной домен: канонический robots продакшена (корневой robots.txt — копия для try_files-fallback, см. routing.conf)
    location = /robots.txt {
        alias /var/www/static/robots.production.txt;
        default_type text/plain;
        access_log off;
    }

    location = /sitemap.xml {
        alias /var/www/static/sitemap.xml;
        default_type application/xml;
        charset utf-8;
        access_log off;
    }

    location ^~ /_sa/ {
        alias /var/www/static/;
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # Keep API on legacy until explicitly migrated
    location ^~ /api/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_ssl_server_name on;
        proxy_ssl_name serenity.agency;
        proxy_ssl_verify off;
        proxy_pass https://serenity_legacy_origin;
    }

    location ^~ /docs/ {
        expires -1;
        add_header Cache-Control "no-cache, max-age=0, must-revalidate";
        add_header X-Robots-Tag "noindex, nofollow" always;
        try_files $uri $uri/ =404;
    }

    # Канон листинга блога — /blog/ (см. serenity-router.live.conf и scripts/verify-routing-config.cjs).
    location = /blog {
        return 308 https://serenity.agency/blog/$is_args$args;
    }

    location = /blog/article/7-raz-otmer-kak-sozdat-effektivnyj-sajt-dlya-biznesa {
        return 301 https://serenity.agency/blog/article/;
    }
    location = /blog/article/7-raz-otmer-kak-sozdat-effektivnyj-sajt-dlya-biznesa/ {
        return 301 https://serenity.agency/blog/article/;
    }

    location ^~ /blog {
        expires -1;
        add_header Cache-Control "no-cache, max-age=0, must-revalidate";
        try_files $uri $uri/ =404;
    }

    error_page 419 = @legacy_proxy;

    location / {
        if ($is_new_page = 0) {
            return 419;
        }
        expires -1;
        add_header Cache-Control "no-cache, max-age=0, must-revalidate";
        try_files $uri $uri/ =404;
    }

    location @legacy_proxy {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
        proxy_connect_timeout 10s;
        proxy_ssl_server_name on;
        proxy_ssl_name serenity.agency;
        proxy_ssl_verify off;
        proxy_pass https://serenity_legacy_origin;
    }
}
