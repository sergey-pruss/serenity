{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "serenity",
  "main": "./src/worker.mjs",
  "compatibility_date": "2026-04-26",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/docs", "/docs/*", "/robots.txt"]
  },
  "kv_namespaces": [
    {
      "binding": "AMO_TOKENS_KV",
      "id": "25e31271bdee40ab8d0210d978feed31"
    }
  ]
}
