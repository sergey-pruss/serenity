23.5331 25.2 16.4718V8.74125C25.2 1.67997 23.5331 0 16.4719 0ZM4.63413 11.7562L18.9545 6.23397C19.6079 5.93835 20.2396 6.39147 19.99 7.3922L17.5516 18.884C17.3811 19.7014 16.8892 19.8953 16.2043 19.5181L12.4897 16.7744L10.7039 18.5109C10.6973 18.5173 10.6907 18.5237 10.6841 18.5301C10.4849 18.7227 10.3197 18.8824 9.96006 18.8824L10.2137 15.0927L10.2121 15.0919H10.2137L17.1057 8.87189C17.4078 8.60374 17.0403 8.47208 16.6381 8.71681L8.13144 14.0839L4.45482 12.937C3.66248 12.6939 3.65682 12.1487 4.63413 11.7562Z" fill="white" data-v-23015bc0 data-v-23015bc0></path></svg> <a href="https://t.me/Serenity_Agency_bot" target="_blank" data-v-23015bc0><span data-v-23015bc0>Написать в чат</span></a></li></div></div></div> <!----></div></div></div><script>window.__NUXT__=(function(a,b,c,d,e,f,g,h,i,j,k,l,m,n,o,p,q,r,s,t,u,v,w,x,y,z,A,B,C,D,E,F,G,H,I,J,K,L,M,N,O,P,Q,R,S){s.id=103;s.name=t;s.code=n;s.description="Разрабатываем айдентику, которая визуально передает суть продукта, формирует яркие ассоциативные образы и легко запоминается.";s.content=[{component:"title-block",name:"Титульный блок",data:{title:u,vimeo:b,yotobe:b,type:"movie",movie:"F9X3SERIY94cBVeXcPBJDf7Bw0YYqRQDKFm5fby4.mp4",mobile_movie:"AFTHtk5bWHZIUUtsprCgtcGi4DQRzKEkdZwGFrFi.mp4",poster:b,pictures:[],mobile_pictures:[],full_screen_picture:b,mobile_full_screen_picture:b,size:c,subtitle:v}},{component:"facts-block",name:"Блок с фактоми",data:{title:"Фирменный стиль бренда&nbsp;— это&nbsp;четкая и&nbsp;запоминающаяся визуальная идентификация организации, которая&nbsp;вызывает доверие и&nbsp;повышает лояльность к&nbsp;ней.",titleLarge:c,description:{main:"Выделяем бренд среди рекламного шума. Укрепляем имидж, создавая целостную картину: логотип, цвета, шрифты, маскот и&nbsp;другие графические элементы гармонично сочетаются и&nbsp;поддерживают общий тон компании. Вызываем чувства и&nbsp;эмоции в&nbsp;соответствии с&nbsp;концепцией и&nbsp;платформой бренда.",descriptions:[]},facts:{desktop:{columns:[{items:[{isImage:c,number:"1",text:"Создаем узнаваемую и&nbsp;современную оболочку для&nbsp;будущего бренда.",uid:"f7e20462-82f9-4b47-9d29-b13cb5fb6d33"},{isImage:c,number:"2",text:"Подчеркиваем ценности бренда и&nbsp;усиливаем эмоциональную связь.",uid:"c88b29f1-34c4-4baa-8fcf-16f1b5a0cb0d"},{isImage:c,number:"3",text:"Повышаем общую заинтересованность и&nbsp;лояльность аудитории.",uid:"d8e138aa-0450-4387-9957-4f16f05167f7"}],uid:"8c9e84ea-8e8f-41cd-993e-3d1bcde0ec21"}]},tablet:{columns:[],bottomImage:{isActive:c}},mobile:{columns:[]}}}},{component:h,name:i,data:{title:{content:" Наш подход",large:f},counter:c,description:b,blocks:[[{title:"Конкретность",description:"Создаем айдентику, в&nbsp;основе которой лежит позиционирование бизнеса, а&nbsp;не&nbsp;просто креативное абстрактное решение.",media:b,tooltip:{visible:c,content:b},uid:"d45c8a0b-eef6-4abc-bff2-b9fd0fa3c8bb"},{title:"Уникальность",description:"Ищем нестандартные решения, чтобы&nbsp;отстроиться от&nbsp;всех конкурентов, избегая ненужных сравнений. Создаем визуальные и&nbsp;вербальные образы, которые помогают быстро и&nbsp;однозначно идентифицировать бренд.",media:b,tooltip:{visible:c,content:b},uid:"dd075ad2-595a-46a6-955b-72325e710aa8"}],[{title:"Простота",description:"Стремимся к&nbsp;легкости восприятия смыслов через&nbsp;отсутствие лишних отвлекающих или&nbsp;путающих элементов.",media:b,tooltip:{visible:c,content:b},uid:"86ef0d9e-4f65-4a0b-ab54-b90a3bff6278"},{title:"Доходчивость",description:"Доносим преимущества продукта, передаем философию компании, создаем позитивные ассоциации и&nbsp;вызываем у&nbsp;аудитории чувство принадлежности к&nbsp;бренду. ",media:b,tooltip:{visible:c,content:b},uid:"5b3f950e-20e0-4f80-be54-9346b1df2da4"}],[{title:"Системность",description:"Сохраняем узнаваемость в&nbsp;каждой точке касания&nbsp;— сайт, социальные сети, реклама, вывеска, носители. Масштабируем на&nbsp;физические носители и&nbsp;каналы коммуникации без&nbsp;потери единства стиля и&nbsp;смысла.",media:b,tooltip:{visible:c,content:b},uid:"7eafa220-2337-4692-81be-144eee8987cd"},{title:"Синергия",description:"Повышаем эффективность всей кампании за&nbsp;счет синергии специалистов. Каждый отдел ознакомлен с&nbsp;общей концепцией и&nbsp;создает решения, ориентируясь на&nbsp;единые цели и&nbsp;стратегию. Это минимизирует несостыковки в&nbsp;работах.",media:b,tooltip:{visible:c,content:b},uid:"10a62052-83d1-4376-a8d5-41a8ec9817e7"}]],contentDie:[]}},{component:o,name:p,data:[{id:112,name:"The Start",background_image:"VI2tsA9jA7q9VTVl9DNFi09BaDaOWE9PaZf2DQtg.webp",poster:a,description:"Разработали для клиента фирменный стиль, масштабировав его в&nbsp;оформление стендов, мерча, дизайн приложения и&nbsp;других носителей.",video:a,subtitle:"Сервис бронирования билетов на&nbsp;художественные курсы и&nbsp;арт-пространства в&nbsp;Гонконге.",button_text:q,button_link:"https:\u002F\u002Fwww.behance.net\u002Fgallery\u002F130002443\u002FThe-Start-Brand-Identity",background_small:"cpanp0djmzkn88357qf6x2WIpbgGc6kDDsmUp3hU.webp",white_colors:e,created_at:"2024-09-09T12:48:32.000000Z",updated_at:"2025-10-30T10:53:42.000000Z",categories:j,tags:k,big_font:d,mobile_picture:a,tablet_picture:a,mobile_video:a,hidename:"The Start (для ФС)",is_resource:d}]},{component:h,name:i,data:{title:{content:"Этапы разработки айдентики",large:f},counter:c,description:"Проводим брифинг, узнаем пожелания и ограничения, определяем задачу и&nbsp;общее направление. Выясняем, на&nbsp;каких&nbsp;особенностях делать акценты, и&nbsp;как&nbsp;заинтересовать аудиторию. ",blocks:[],contentDie:[]}},{component:h,name:i,data:{title:{content:"Исследование",large:c},counter:f,description:"Изучаем бизнес и&nbsp;аудиторию, бренды конкурентов и&nbsp;лучшие дизайнерские решения в&nbsp;сфере вашей товарной категории.",blocks:[[{title:"Брифинг",description:"Анализируем позиционирование компании, изучаем сильные стороны бизнеса, выделяем преимущества. Собираем полученную информацию, чтобы&nbsp;затем гармонично вплести ее&nbsp;в&nbsp;визуальную концепцию и&nbsp;идентификацию, которые&nbsp;будут эффективно доносить качества до&nbsp;аудитории.",media:b,tooltip:{visible:c,content:b},uid:"0a4503ef-dfe2-4058-977c-a70aa842f83c"},{title:"Изучение тенденций",description:"Анализируем лучшие отечественные и&nbsp;зарубежные решения в&nbsp;вашей нише, изучаем тренды рынка.",media:b,tooltip:{visible:c,content:b},uid:"e3d21d49-aa58-4ff9-bbb8-e23d96c00625"}],[{title:"Анализ ЦА",description:"Определяем сегменты аудитории и&nbsp;что&nbsp;их&nbsp;объединяет. Фиксируем наиболее важные для&nbsp;целевой аудитории точки касания с&nbsp;вашей компанией. Определяем направление будущего стиля и&nbsp;наиболее важные каналы коммуникации.",media:b,tooltip:{visible:c,content:b},uid:"cf03665e-1125-499b-85ec-08d4f55bbdf1"}],[{title:"Конкуренты",description:"Изучаем бренды конкурентов, отмечаем сильные и&nbsp;слабые стороны айдентики, ищем закономерности. Формируем список референсов, подмечаем интересные решения и&nbsp;создаем уникальный стиль, чтобы&nbsp;избежать повторений и&nbsp;выделиться на&nbsp;рынке.",media:b,tooltip:{visible:c,content:b},uid:"7aa85ef5-2118-480f-b628-e78eaca384e8"}]],contentDie:[]}},{component:h,name:i,data:{title:{content:"Реализация",large:c},counter:f,description:"Разрабатываем дизайн-систему, в&nbsp;соответствии с&nbsp;которой будут оформляться все&nbsp;каналы коммуникации.",blocks:[[{title:"Мудборд",description:"Начинаем работу с&nbsp;создания мудборда, задача которого&nbsp;— сопоставить наше видение будущего дизайна с&nbsp;вашим. С&nbsp;помощью подборки изображений передаем настроение, чувства и&nbsp;эмоции, которые&nbsp;должен вызывать бренд у&nbsp;вашей аудитории. Согласовываем с&nbsp;вами и&nbsp;переходим к&nbsp;следующему этапу.",media:b,tooltip:{visible:c,content:b},uid:"27868264-f934-4854-8164-d86a1d18a879"}],[{title:"Логотип",description:"Центральный элемент брендинга, на&nbsp;основе которого создаем остальные аспекты фирменного стиля. Разрабатываем три&nbsp;концепции логотипа и&nbsp;примеры использования. Вместе выбираем наиболее подходящий вариант и&nbsp;дорабатываем с&nbsp;учетом ваших&nbsp;пожеланий.",media:b,tooltip:{visible:c,content:b},uid:"144f13f2-d61b-4eff-9672-251c537c9334"}],[{title:"Айдентика",description:"Дизайн-система из&nbsp;дополнительных элементов, которые&nbsp;послужат составными в&nbsp;оформлении каналов коммуникаций. Создаем элементы стиля, подбираем шрифты и&nbsp;цветовое исполнение. Брендируем каналы коммуникации, выбранные исходя из&nbsp;специфики вашего&nbsp;бизнеса.",media:b,tooltip:{visible:c,content:b},uid:"cfc7e3f2-a8a8-43c5-8509-0984b69effe0"}]],contentDie:[]}},{component:o,name:p,data:[{id:w,name:x,background_image:"QGOLgSZydO9aIspDgkyi7G4fNiIZnVWk5AJ30bKA.webp",poster:a,description:"Подобрали цветовую палитру, разработали логотип, знак, этикетки для&nbsp;всех товаров, дизайн нового сайта и&nbsp;оформили социальные сети.",video:a,subtitle:"Новый бренд производителя мясных изделий.",button_text:q,button_link:y,background_small:"6Fajno2hglwrAzSZsTodBDmgGwiQwiyxkzVsR3By.webp",white_colors:e,created_at:"2024-09-09T12:56:57.000000Z",updated_at:"2026-04-14T10:32:17.000000Z",categories:j,tags:k,big_font:d,mobile_picture:a,tablet_picture:a,mobile_video:a,hidename:"Сытные угодья (для ФС)",is_resource:d},{id:113,name:"Neela Springs",background_image:"j1VKurBZyyfhzcpalknvlKFs6m2Nrg5P8C2ezlbz.webp",poster:a,description:"Нам предстояло создать айдентику для&nbsp;проверенного временем, надежного и&nbsp;масштабного игрока на&nbsp;рынке, но&nbsp;при&nbsp;этом отразить высокие ценности и&nbsp;проактивность бренда. Мы&nbsp;решили это&nbsp;сделать через&nbsp;главный образ компании — зимородка.",video:a,subtitle:"Производитель питьевой воды с&nbsp;доставкой по&nbsp;Москве и&nbsp;Санкт-Петербургу.",button_text:a,button_link:a,background_small:"niBhH8o1n2MgmEzyTGDtkPHcNMCcbacBJ6lrG3UX.webp",white_colors:e,created_at:"2024-09-09T12:54:35.000000Z",updated_at:"2025-10-30T10:55:30.000000Z",categories:j,tags:k,big_font:d,mobile_picture:"4GhGnc5iaKDf67NI8K690mX2WF8w49vXaUsObjJe.webp",tablet_picture:a,mobile_video:a,hidename:"Neela Springs (для ФС)",is_resource:d}]},{component:h,name:i,data:{title:{content:"Оформление каналов и&nbsp;инструкции",large:c},counter:f,description:"Проводим визуальную и&nbsp;функциональную настройку всех каналов взаимодействия вашего&nbsp;бренда с&nbsp;аудиторией. ",blocks:[[{title:"Оформление",description:"Оформляем коммуникационные каналы в&nbsp;единой концепции, обеспечивая целостность и&nbsp;индивидуальность бренда на&nbsp;всех&nbsp;платформах.",media:b,tooltip:{visible:c,content:b},uid:"c0040b99-67e0-4ea9-a744-323b05a473c8"}],[{title:"Руководство",description:"Создаем подробное руководство по&nbsp;использованию фирменного стиля, включая рекомендации по&nbsp;цветовой палитре, шрифтам, логотипам и&nbsp;графическим элементам. Ваш бренд будет выглядеть цельно во&nbsp;всех точках контакта с&nbsp;клиентами, поддерживая узнаваемость и&nbsp;лояльность.",media:b,tooltip:{visible:c,content:b},uid:"4b62ec79-dfd0-4487-a963-577460d91c06"}],[{title:"Шаблоны",description:"Передаем шаблоны для рекламных баннеров, визиток, писем и&nbsp;презентаций, чтобы&nbsp;у&nbsp;клиентов и&nbsp;партнеров создавался понятный образ корпоративной культуры.",media:b,tooltip:{visible:c,content:b},uid:"611caa6d-620a-4cb2-a7de-9fad3ce22666"}]],contentDie:[]}},{component:h,name:i,data:{title:{content:"Результат",large:f},counter:c,description:"Мы создаем решение, которое&nbsp;формирует целостный визуальный образ бренда. Новый фирменный стиль ложится в&nbsp;основу необходимых цифровых и&nbsp;печатных материалов и&nbsp;других носителей.",blocks:[],contentDie:[]}},{component:o,name:p,data:[{id:116,name:"Axle",background_image:"GGEojtUnuk1dABaPwGMugYfhRb4Z7r1o2tfmPhtM.webp",poster:a,description:"В основу айдентики легла «система», которая&nbsp;упорядочивает хаос в&nbsp;компании. Отразили эту&nbsp;идею также в&nbsp;графическом паттерне из&nbsp;сетки.",video:a,subtitle:"Разработчик систем для&nbsp;оптимизации рутинных процессов в&nb