23.5331 25.2 16.4718V8.74125C25.2 1.67997 23.5331 0 16.4719 0ZM4.63413 11.7562L18.9545 6.23397C19.6079 5.93835 20.2396 6.39147 19.99 7.3922L17.5516 18.884C17.3811 19.7014 16.8892 19.8953 16.2043 19.5181L12.4897 16.7744L10.7039 18.5109C10.6973 18.5173 10.6907 18.5237 10.6841 18.5301C10.4849 18.7227 10.3197 18.8824 9.96006 18.8824L10.2137 15.0927L10.2121 15.0919H10.2137L17.1057 8.87189C17.4078 8.60374 17.0403 8.47208 16.6381 8.71681L8.13144 14.0839L4.45482 12.937C3.66248 12.6939 3.65682 12.1487 4.63413 11.7562Z" fill="white" data-v-23015bc0 data-v-23015bc0></path></svg> <a href="https://t.me/Serenity_Agency_bot" target="_blank" data-v-23015bc0><span data-v-23015bc0>Написать в чат</span></a></li></div></div></div> <!----></div></div></div><script>window.__NUXT__=(function(a,b,c,d,e,f,g,h,i,j,k,l,m,n,o,p,q,r,s,t,u,v,w,x,y,z,A,B,C,D,E,F,G,H,I,J,K,L,M,N,O,P,Q){q.id=83;q.name=m;q.code=n;q.description="Запуск контекстных рекламных кампаний на площадках Яндекс и Google — повысим трафик вашего сайта, увеличим аудиторию бренда и доведем горячих клиентов до покупки.";q.content=[{component:"title-block",name:"Титульный блок",data:{title:m,type:"full_screen_picture",movie:b,mobile_movie:b,poster:b,pictures:[],mobile_pictures:[],full_screen_picture:"xjhFEA49677OGQDTXjw6he9xnUh71ef9GgvspTHz.webp",mobile_full_screen_picture:"Kp6Jy1TO8NbiJgnBpD8XJYoUcw80ZFM1TcVDLr82.webp",subtitle:r}},{component:k,name:l,data:{title:{content:"Запуск и настройка контекстной рекламы: этапы работы",large:c},counter:c,description:b,blocks:[[{title:"Анализируем конкурентов и лидеров отрасли",description:"Находим потенциальных конкурентов в выбранной нише, определяем лидеров рынка. \u003Cbr\u003E\u003Cbr\u003EАнализируем, откуда и почему к ним приходят клиенты, что покупают, какие офферы они транслируют покупателям и какие цены устанавливают на товары и услуги. \u003Cbr\u003E\u003Cbr\u003EСобираем множество инсайтов и перекрываем их более ценностными предложениями.",media:b,tooltip:{visible:c,content:b},uid:"c410a237-fc67-4db3-89e4-b5e21e322893"},{title:"Настраиваем аналитику",description:"Подключаем системы аналитики для будущей оптимизации и оценки эффективности рекламы по ключевым показателям и сверяем с прогнозом. \u003Cbr\u003E\u003Cbr\u003EДелаем настройку целей на сайте, подключаем динамический коллтрекинг и email-трекинг, что позволит отслеживать совершение конверсий с разных источников и грамотно распределять рекламный бюджет.",media:b,tooltip:{visible:c,content:b},uid:"d66490ca-b2e4-4f4e-9e3b-636f34b74315"}],[{title:"Проводим аудит посадочных страниц",description:"Анализируем как ведут себя пользователи на сайте с помощью Яндекс Метрики и Google Analytics. \u003Cbr\u003E\u003Cbr\u003EПредлагаем решения, которые с помощью синергии дизайна и юзабилити сделают клиентский опыт и путь до совершения покупки, максимально комфортным и быстрым. \u003Cbr\u003E\u003Cbr\u003EОриентируемся на показатели, важные для завершения воронки от просмотра рекламы до совершения транзакции или заказа.\n",media:b,tooltip:{visible:c,content:b},uid:"9a094692-04c0-4c87-8418-1edb238a5efe"},{title:"Создаем и запускаем рекламные кампании",description:"Формируем технические задания на создание фидов товаров для загрузки их в кампании. \u003Cbr\u003E\u003Cbr\u003EСоздаем баннеры для медийных форматов и рекламы в сетях. \u003Cbr\u003E\u003Cbr\u003EПишем тексты рекламных объявлений с учетом уникальных преимуществ бренда. \u003Cbr\u003E\u003Cbr\u003EОсуществляем итерационную настройку и запуск кампаний от наиболее эффективных к наиболее охватным.",media:b,tooltip:{visible:c,content:b},uid:"137c2725-f098-48b5-98f8-7adeb1fba4d3"}],[{title:"Формируем стратегию продвижения",description:"Собираем семантическое ядро, формируем портреты аудиторий для показа рекламы. Распределяем бюджет между рекламными форматами и создаем медиаплан на период от 4 месяцев до 1 года. \u003Cbr\u003E\u003Cbr\u003EВ медиаплане формируем прогноз трафик на сайт, количество и стоимость целевых действий. \u003Cbr\u003E\u003Cbr\u003EПодробный прогноз помогает определить, как будет работать контекстная реклама и какие гипотезы дадут наибольший эффект.",media:b,tooltip:{visible:c,content:b},uid:"deeb9128-fc64-45ea-8847-5e3765ee5c9e"},{title:"Анализируем и оптимизируем",description:"Контекстная реклама требует постоянного анализа и обновления кампаний, чтобы сохранять эффективность при изменении конкуренции. \u003Cbr\u003E\u003Cbr\u003EЭффективность рекламы мы измеряем с помощью аналитики: показываем детальные отчеты, которые помогают понять суть работы, результаты и при этом не запутаться. \u003Cbr\u003E\u003Cbr\u003EПо итогам собранных данных непрерывно оптимизируем кампании: масштабируем эффективные, перераспределяем бюджет и корректируем менее результативные, строим гипотезы и намечаем цели. Выстраиваем фокус на рост количества целевых действий (звонков, заявок, продаж с сайта) и уменьшение их стоимости.",media:b,tooltip:{visible:c,content:b},uid:"53313821-3685-4150-9c56-67dbcd8585cf"}]],contentDie:[]}},{component:o,name:p,data:[{id:40,name:"DarkRain",background_image:"PyRFrlyYAq8BN6JyIJhlOwIikEfOnsyOYQc2uAJy.webp",poster:a,description:"Сформировали гипотезы и реализовали наиболее рабочие из них. В результате в 5 раз увеличили продажи, в 10 раз увеличили клиентскую базу, в 6 раз увеличили количество поисковых запросов бренда.",video:a,subtitle:"Увеличили конверсию сайта для бренда ювелирных украшений.",button_text:i,button_link:s,background_small:"aUi8YfnntliHTrn6OU6JOaCMEcOOY8NGt16t15Zh.webp",white_colors:d,created_at:"2023-08-28T23:10:08.000000Z",updated_at:"2025-10-30T09:52:46.000000Z",categories:f,tags:f,big_font:e,mobile_picture:a,tablet_picture:a,mobile_video:b,hidename:"DarkRain (контекст)",is_resource:d},{id:41,name:"Orange",background_image:"OBIK6EwpuWYXIOTf2Xmh8G0lpcgYbi0geXPRJXdC.webp",poster:a,description:"Исследовали посетителей из поисковых систем и определили, что наиболее релевантная аудитория приходит из Google. Запустили в нем контекстную рекламу и вели клиентов на интересующие страницы услуг. Увеличили целевой трафик на 96% и снизили показатель отказов на сайте в 5,4 раза.",video:a,subtitle:"Привели трафик на сайт международного  интегратора IT-сервисов",button_text:i,button_link:"https:\u002F\u002Fserenity.agency\u002Fcase\u002Forange",background_small:"OL9uTgUvGZ61bfsbXisNg9eGKHtDe1YJrNCmBpMJ.webp",white_colors:d,created_at:"2023-08-28T23:12:47.000000Z",updated_at:"2025-10-30T09:53:45.000000Z",categories:f,tags:f,big_font:e,mobile_picture:a,tablet_picture:a,mobile_video:b,hidename:"Orange (контекст)",is_resource:d}]},{component:k,name:l,data:{title:{content:"Почему работать с нами надежно и выгодно",large:c},counter:c,description:b,blocks:[[{title:"Доступ к инсайтам рынка",description:"Мы являемся сертифицированным партнером Яндекса, благодаря чему получаем доступ к бенчмаркам по нишам и обладаем знаниями о ситуации на рынке. Это позволяет нам делать прогнозы и рекомендовать улучшения, повышающие конверсию сайта.",media:b,tooltip:{visible:c,content:b},uid:"7f073ffd-76a8-4b3b-b67e-2f1a5993c88e"},{title:"Опытная и обученная команда",description:"Все специалисты ежегодно проходят сертификацию и обучаются работе с новыми форматами рекламы. Над стратегией каждого клиента работает команда из менеджеров, специалистов, тимлидеров направлений и дизайнеров, которые ежемесячно проходят обучения и делают аудиты проектов клиентов.",media:b,tooltip:{visible:c,content:b},uid:"1a7c9b59-1be5-45d3-a143-ecd94de7a7a8"}],[{title:"Доступ к закрытым \u003Cbr\u003E инструментам рекламных платформ",description:"Партнерство с Яндекс также дает нам доступ к закрытым бета-тестам новых форматов для наших клиентов, что позволяет первыми использовать их без большого количества конкурентов.",media:b,tooltip:{visible:c,content:b},uid:"a61214b6-1a25-4aa9-8ca9-7ed71b82269a"},{title:"Глубокая аналитика \u003Cbr\u003E и конкурентные стратегии",description:"Мы систематически анализируем все запущенные нами каналы рекламы в интернете и сайты конкурентов, формируем предложения для офферов и отстройки и знаем как привлекать аудиторию конкурентов на сайты наших клиентов.",media:b,tooltip:{visible:c,content:b},uid:"34d01020-fe13-4df0-818b-ef04b33c841d"}],[{title:"Прозрачное ценообразование",description:"Мы предлагаем прозрачные условия работы по настройке контекстной рекламы в Яндекс Директ, без агентских комиссий и лишних расходов. Мы не берем агентскую комиссию с бюджетов — весь рекламный бюджет идет только на рекламу. Наши работы оплачиваются отдельно в зависимости от количества рабочих часов команды на настройку и оптимизацию рекламы.",media:b,tooltip:{visible:c,content:b},uid:"08fd5a2f-fb31-41af-a255-4c8a1c91bc01"},{title:"Соблюдение законодательства \u003Cbr\u003E и модерации",description:"С нами клиентам не приходится заботиться о соблюдении законодательства - мы хорошо знаем все правовые аспекты рекламирования, заблаговременно запрашиваем документы для прохождения модерации и самостоятельно маркируем рекламу.",media:b,tooltip:{visible:c,content:b},uid:"d2094112-69f7-42af-8a82-aab7159e4eee"}]],contentDie:[]}},{component:o,name:p,data:[{id:43,name:t,background_image:"lRowaUhHi4llniaqM0sJTh6wOR8768BJ18FrFLY8.webp",poster:a,description:"В 7 раз увеличили доход клиента и количество обращений до 1 693 с помощью контекстной рекламы. Выделили наиболее выгодные для магазина ценовые диапазоны, наиболее маржинальные товары и продвигали их на торговых площадках.",video:a,subtitle:"Наладили работу отдела продаж и запустили комплексное продвижения магазина мебели.",button_text:i,button_link:"https:\u002F\u002Fserenity.agency\u002Fcase\u002Finternet-magazin-mebeli-skladno",background_small:"XWaIrLTXnpklrUwtL5DpLF3on99xhSrvZr2zG8ZM.webp",white_colors:d,created_at:"2023-08-28T23:17:08.000000Z",updated_at:"2025-10-30T09:58:00.000000Z",categories:f,tags:f,big_font:e,mobile_picture:a,tablet_picture:a,mobile_video:b,hidename:"Складно (контекст)",is_resource:d},{id:58,name:"Digitale",background_image:"FhX7ymsPjK8OwF0gZcquVp0Ipb6Cp6pEAlFYEgYO.webp",poster:a,description:"С помощью контекстной рекламы решали две задачи: поддержка инструментов продвижения и заявки. Продвигались через поисковую и медийную рекламу, а также YouTube. В результате получили 26 000 просмотров на YouTube, 8 700+ переходов на сайт и охватили 130 000 человек.",video:a,subtitle:"Собрали рекордное количество участников на конференцию.",button_text:i,button_link:"https:\u002F\u002Fserenity.agency\u002Fcase\u002Fdigitale",background_small:"AgXyB0RE1MaCMUJyUaIHuFPoMEJfgAOJIWra22qO.webp",white_colors:d,created_at:"2023-10-13T13:24:36.000000Z",updated_at:"2025-10-30T09:58:44.000000Z",categories:f,tags:f,big_font:e,mobile_picture:a,tablet_picture:a,mobile_video:a,hidename:"Digitale (контекст)",is_resource:d},{id:44,name:"Мосплитка",background_image:"9J6f8UhhwDQHAImvRpmi6tadgdnW4BomwW5UgKYj.webp",poster:a,description:"Достигли цели по стоимости заявки с платного трафика уже в первый месяц. Спустя три месяца стоимость снизилась в 1,5 раза. Охватили все бренды магазина, посетителей сайтов конкурентов и весь ассортимент.",video:a,subtitle:"За четыре месяца выполнили план продаж для сети магазинов сантехники и плитки.",button_text:i,button_link:"https:\u002F\u002Fserenity.agency\u002Fcase\u002Fmosplitka",background_small:"FAEjOsR990eC7wWhoqZBIKSksSeDi1eN9XmkBw0K.webp",white_colors:d,created_at:"2023-08-28T23:18:57.000000Z",updated_at:"2025-10-30T09:59:41.000000Z",categories:f,tags:f,big_font:e,mobile_picture:a,tablet_picture:a,mobile_video:b,hidename:"Мосплитка (контекст)",is_resource:d}]},{component:k,name:l,data:{title:{content:"Форматы контекстной рекламы",large:h},counter:c,description:b,blocks:[[{title:"Поисковая контекстная реклама",description:"Привлекаем аудиторию через контекстную рекламу по поисковым запросам, связанным с вашими товарами и услугами. \u003Cbr\u003E\u003Cbr\u003EСамый быстрый и эффективный способ удовлетворить спрос как в высококонкурентных и срочных нишах, так и в нишах с узкой аудиторией.",media:b,tooltip:{visible:c,content:b},uid:"dea36b82-a0fd-48f3-bd3e-ce19d41285b2"},{title:"Геомедийная контекстная реклама",description:"Разместим рекламу в навигационных и картографических сервисах экосистемы Яндекса в виде премиум-баннеров, брендированных пинов по маршруту и цифровых билбордов. \u003Cbr\u003E\u003Cbr\u003EПривлечем внимание к бренду пользователей, которые стоят в пробке, смотрят карту метро и построим маршрут до ближайшего филиала бренда.",media:b,tooltip:{visible:c,content:b},uid:"1e425b93-378e-440b-8604-2123138d144f"}],[{title:"Баннерная контекстная реклама в сетях",description:"Формируем яркие баннеры для привлечения аудитории по интересам в нише не только на площадках рекламных сетей, но и на сайтах партнеров. \u003Cbr\u003E\u003Cbr\u003EКонтекстная реклама в рекламных сетях помогает повысить узнаваемость бренда, а поисковая контекстная реклама через Директ возвращает пользователей, которые уже интересовались продуктом.",media:b,tooltip:{visible:c,content:b},uid:"a8bc4fef-540d-4338-be81-8d54afc4a48e"},{title:"Продвижение мобильных приложений",description:"Контекстная реклама, нацеленная на установки приложений и in-app конверсии по минимальной цене. \u003Cbr\u003E\u003Cbr\u003EПри настройке контекстной рекламы в Яндекс Директ мы подбираем оптимальные сегменты аудитории и креативы для повышения конверсии. \u003Cbr\u003E\u003Cbr\u003EПривлечем пользователей мобильных приложений на iOS и Android из официальных маркетов с оплатой за клики или установки. ",media:b,tooltip:{visible:c,content:b},uid:"0237e4c9-b7cd-458b-b529-63136b03d17a"}],[{title:"Медийная контекстная реклама в сетях",description:"С помощью информативных видеороликов и статичных баннеров формируем у аудитории с подходящим портретом интерес к бренду, повышаем лояльность, приводим трафик на сайт. \u003Cbr\u003E\u003Cbr\u003EДейственный способ быстро рассказать о масштабных акциях, новых товарных линейках и сохранить преданность бренду.",media:b,tooltip:{visible:c,content:b},uid:"c4e4cce7-ef1e-498c-9a1a-220f4c2e85aa"},{title:"Реклама магазинов на маркетплейсах",description:"Запустим контекстную рекламу на продвижение магазинов и товаров на Яндекс Маркете, Ozon, Wildberries и Авито. Покажем товары покупателям, активно совершающим заказы в интернете и приведем их в каталог магазина.",media:b,tooltip:{visible:c,content:b},uid:"3663b774-ed3d-4ba0-8ffa-96baa7eb1ca9"}]],contentDie:[]}},{component:o,name:p,data:[{id:45,name:u,background_image:"tIebbzcPTKO4SeH29iEJgCXm17X4e5yEEVaayuSk.webp",poster:a,description:"Определили наилучшее время для показа рекламы и увеличили известность бренда. В 2 раза снизили стоимость и в 2,5 раза увеличили число обращений, в 1,5 раза увеличили конверсию из обращения в запись.",video:a,subtitle:"Создали постоянный поток заявок  для клиники пластической хирургии.",button_text:i,button_link:"https:\u002F\u002Fserenity.agency\u002Fcase\u002Fkompozit",background_small:"kaWMGsNykvZjvteRv6UFdcaisFJZiYF4MKZngk4T.webp",white_colors:d,created_at:"2023-08-28T23:20:36.000000Z",updated_at:"2025-10-30T10:10:11.000000Z",categories:f,tags:f,big_font:e,mobile_picture:a,tablet_picture:a,mobile_video:b,hidename:u,is_resource:d},{id:46,name:"Good Wood",background_image:"x98VN5hENJAGjzVYlNrzFujMFB06AbmDM2bxJAgO.webp",poster:a,description:"Использовали контекстную рекламу как дополнительный канал для увеличения охвата и возврата клиентов. Запустили ремаркетинг. Собрали 5700 человек как общий объем аудитории, продали 805 билетов из 600 планируемых за 1,5 месяца.",video:a,subtitle:"Привлекли участников на бизнес-конференцию.",button_text:i,button_link:"https:\u002F\u002Fserenity.agency\u002Fcase\u002Fgood-wood",background_small:"qw3PhWZ8u3fJRlJx6B62atRpwbFSNrQjQlpyxyFV.webp",white_colors:d,created_at:"2023-08-28T23:21:57.000000Z",updated_at:"2025-10-30T10:00:37.000000Z",categories:f,tags:f,big_font:e,mobile_picture:a,tablet_picture:a,mobile_video:b,hidename:"Good Wood (контекст)",is_resource:d},{id:47,name:"AWM-Trade",background_image:"nzJ8821fyX7m2gDqHHItwqH0upll1mGXsZoRiZr6.webp",poster:a,description:"Определили через поисковые системы, как потенциальные клиенты выбирают мототехнику, и создали для них подходящую рекламу. В 3 раза увеличили посещаемость сайта и снизили процент отказа до 13%.",video:a,subtitle:"Продвижение для дистрибьютора квадроциклов и мотоциклетной техники.",button_text:i,button_link:"https:\u002F\u002Fserenity.agency\u002Fcase\u002Fawm-trade",background_small:"ZuYUgksixiZnyvJH6amXm9zo4pO5U5ZS5lmfSSNV.webp",white_colors:d,created_at:"2023-08-28T23:33:58.000000Z",updated_at:"2025-10-30T10:02:53.000000Z",categories:f,tags:f,big_font:e,mobile_picture:a,tablet_picture:a,mobile_video:b,hidename:"AWM-Trade (контекст)",is_resource:d}]},{component:k,name:l,data:{title:{content:"Пакеты",large:c},counter:c,description:b,blocks:[],contentDie:[]}},{component:"dies-block",name:"Плашки - Другая услуга",data:{dies:[{title:"Минимальный",description:"Продвижение 1-2 услуг в одной геолокации. Поисковая и товарная реклама, РСЯ, ретаргетинг.\u003Cbr\u003E\u003Cbr\u003E\u003Ci\u003EПодходит для B2b услуг, интернет магазинов с одной категорией товаров, небольшого локального бизнеса.\u003C\u002Fi\u003E\n",price_from:"От 107 000",link:b,picture:b,uid:"28988432-eead-4ede-940f-028727c2a7d9"},{title:"Оптимальный",description:"Продвижение 3-5 услуг в нескольких геолокациях. Поисковая и товарная реклама, РСЯ, ретаргетинг, медийная реклама, посевы в телеграм-каналах.\u003Cbr\u003E\u003Cbr\u003E\u003Ci\u003EПодходит для B2b с широким спектром услуг, интернет магазинов с 5-10 категориями товаров, среднего бизнеса в нескольких регионах.\u003C\u002Fi\u003E\n",price_from:"От 128 000",link:b,picture:b,uid:"1f218a5e-6906-4f66-83bb-97fc16b2dd79"},{title:"Расширенный",description:"Продвижение широкого ассортимента услуг и товаров. Поисковая и товарная реклама, РСЯ, ретаргетинг, медийная и геомедийная реклама, посевы в телеграм-каналах, наружная реклама.\u003Cbr\u003E\u003Cbr\u003E\u003Ci\u003EПодходит для международного и федерального бизнеса B2B и B2C, крупных интернет магазинов в нескольких регионах.\u003C\u002Fi\u003E\n",price_from:"от 149 000",link:b,picture:b,uid:"f0bf9da1-77e6-496e-9db2-c487ec17434c"}]}},{component:"forms-block",name:"Форма",data:{title:"Заказать контекстную рекламу",price:b,description:"Стоимость настройки контекстной рекламы в Яндекс Директ зависит от объема кампаний, уровня конкуренции и поставленных целей. \u003Cbr\u003E \u003Cp\u003E&nbsp;\u003C\u002Fp\u003EЦена за настройку и ведение контекстной рекламы — от 107 000 ₽ \u003Cbr\u003E Рекламный бюджет — от 300 000 ₽"}},{component:"team-block",name:v,data:{title:v,description:"Над настройкой и созданием рекламной кампании параллельно трудятся несколько специалистов. Работаем над проектом в синергии, что помогает оптимизировать производственные процессы и предоставить результат в точные сроки.",team_members:[{title:"Лидер направления",description:"Участвует в разработке стратегии, рекомендует подходящие инструменты. Курирует работу специалиста по контекстной рекламе и аналитика.",movie:"K5uCBXxVoy1Iw4TeYlW8HGKYrRRQLH8as4dlTzBS.png",uid:"6f71539b-47ae-40fb-b1f6-2ada64852998"},{title:"Специалист по рекламе",description:"Анализирует рекламу конкурентов, посадочные страницы, создает стратегию и медиаплан. Настраивает и ведет рекламные кампании, проводит систематическую оптимизацию, готовит необходимые отчеты и участвует в отчетных встречах.",movie:"DG8ojXn8kY3VSl2SpwEq6kW4XE06wd5LVtRBFMzQ.png",uid:"13581433-1ea3-4776-b3bc-92dbbfa107f4"},{title:"Аналитик",description:"Подключает и настраивает аналитические системы. Формирует отчеты. Дает рекомендации по ведению рекламной кампании.",movie:"FR1HgKzqC6qLTXeLohHsyLaSCza6IqENwyhl81Jz.png",uid:"062d9711-d699-4bb2-ab76-84994e7d4887"},{title:"Аккаунт-менеджер",description:"Является связующим звеном между агентством и заказчиком, общается с клиентом, следит за корректностью документов, договоров и актов. Организует синергию каналов продвижения, развития бренда и разработки посадочных страниц.",movie:"eIcGe0SwBMijSHMjuadbPh7UHFh7Ak6QT5al6MPd.png",uid:"8bdf1b96-85e8-4a56-9412-becc2fb40b59"},{title:"Дизайнер",description:"Создает визуальную составляющую для баннеров в стилистике бренда заказчика.",movie:"LPWTVmz4Uj3IrCCTt0GY2SNYMHqltl02mh450bYD.png",uid:"d76cf7a0-eb5d-4fb6-808f-26514aeac4d1"},{title:"Проджект-менеджер",description:"Управляет командой и осуществляет промежуточный контроль результатов. Отвечает за эффективность продвижения. Организует синергию каналов продвижения, развития бренда и разработки посадочных страниц.",movie:"iKreNjC8JfllzB17R6HaF65AABcVUUoU8YNNCqR3.png",uid:"2fa8915c-c191-45b8-b1e7-1c8b572dcce3"}]}},{component:"faq-block",name:"Вопрос ответ",data:{questions:[{question:"Что нужно, чтобы запустить рекламу в Яндексе?",answer:"Подготовленная к посадке трафика страница, конкурентные условия, менеджеры для обработки заявок, рекламный бюджет, настроенная аналитика. Практически все из этого мы можем сделать силами агентства, кроме рекламного бюджета и обработки заявок.",uid:"989b8ea4-d3ee-46eb-a926-64575d7445c0"},{question:"Можете ли вы запустить контекстную рекламу в Google?",answer:"Мы делаем настройку и ведем рекламу в Google Ads для бизнеса за пределами РФ. В России продвижение в Google мы реализуем с помощью SEO-оптимизации сайта.",uid:"a3fd333c-cd4e-412d-9dff-431c7f1f44b6"},{question:"Когда можно увидеть первые результаты от рекламы?",answer:"В зависимости от ваших товаров и услуг. Если вы оказываете или продаете их единоразово, здесь и сейчас, то первые результаты от контекстной рекламы вы увидите в течение первого месяца после запуска. Если в вашей сфере у клиентов долгий срок принятия решения - от 2 месяцев до года, первые результаты по каналу можно будет оценить в течение этого срока.",uid:"e58a626c-f2e5-4fd5-ae77-7ad9f235a37b"},{question:"Какой рекламный бюджет нужен для старта?",answer:"Рекламный бюджет зависит от стоимости ваших товаров и услуг, для ниши недвижимости и продажи косметики бюджеты будут сильно отличаться. Важным аспектом также является география показов рекламы - в Москве и Санкт-Петербурге бюджеты будут выше, чем в большинстве других регионов. Однако для эффективного старта работы и получения первых результатов мы рекомендуем выделять от 300 000 рублей в первые месяцы и увеличивать бюджеты если KPI по конверсиям или продажам соблюдаются. ",uid:"47a43d90-e520-451a-905c-520753eea7cb"},{question:"Есть ли скидки на работы при увеличении бюджета?",answer:"Наше агентство не берет комиссию от бюджетов наших клиентов, однако получаем ее от рекламных площадок. Благодаря этому цена ведения может быть снижена при увеличении бюджета. Свяжитесь с нами и мы подготовим предложение с этим учетом.",uid:"f8dfcf45-8ebd-43e2-8737-1a122cc1f7b6"},{question:"Вы делаете маркировку контекстной рекламы?",answer:"Да, мы маркируем всю запущенную нами рекламу в интернете через ОРД  Яндекс и отправляем отчеты в ЕРИР.",uid:"dea8a633-189d-4b45-88a9-57aba62e0f42"},{question:"Что входит в настройку контекстной рекламы?",answer:"В настройку контекстной рекламы входят сбор семантики, создание объявлений, подбор минус-слов, настройка целей и оптимизация по ключевым показателям, анализ конкурентов, посадочных страниц и рекомендации по изменению для повышения конверсии в целевое действие. ",uid:"84941020-95f3-4757-81d7-1680a2a55303"},{question:"Сколько стоит настройка и ведение контекстной рекламы?",answer:"Стоимость настройки и ведения контекстной рекламы в нашем агентстве начинается от 107 000 ₽. Если реклама ведется в нескольких регионах или используется несколько форматов, цена рассчитывается индивидуально.",uid:"3e76e172-2cb9-4e98-a8b9-389f92c36b90"},{question:"Где вы работаете и по каким регионам доступна контекстная реклама?",answer:"Мы настраиваем и ведем контекстную рекламу по всей России. Для Москвы и Санкт-Петербурга действуют те же условия и стоимость, что и для других регионов.",uid:"11e1259b-cc52-4da3-8e0f-73e1f30d98c7"}]}},{component:"awards-block",name:"Награды",data:{awards:[{id:169,title:"Connect",date:"