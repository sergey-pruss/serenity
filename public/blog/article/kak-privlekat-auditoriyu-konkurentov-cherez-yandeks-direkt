003Cblockquote\u003E\n\u003Cp class=\"article_decoration_first article_decoration_last\"\u003EЛоготип — это инструмент бренда, который транслирует идею бизнеса. В нашем случае — объединение оздоровления и релаксации. Так мы исключили ассоциацию бренда лишь с медицинскими учреждениями.\u003C\u002Fp\u003E\n\u003C\u002Fblockquote\u003E\n\u003Cp class=\"article_decoration_first\"\u003EМы разработали два логотипа клиники — в минималистичном стиле и в пастельных цветах с природными мотивами.\u003C\u002Fp\u003E\n\u003Cp class=\" article_decoration_last article_decoration_before\"\u003EЗаказчику понравился логотип в виде цветка. Он показался ему подходящим — перекликается с услугами клиники, символизирует красоту и оздоровление.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:S,type:ad,photos:[{ID:i,id:i,title:hh,filename:aur,url:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F4.jpg",alt:a,author:u,description:a,caption:a,name:hh,date:"2018-11-30 14:26:44",modified:"2018-11-30 14:48:31",mime_type:K,type:v,icon:w,width:aF,height:1058,sizes:{thumbnail:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F4-300x300.jpg","thumbnail-width":h,"thumbnail-height":h,medium:auP,"medium-width":k,"medium-height":auQ,medium_large:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F4-768x339.jpg","medium_large-width":z,"medium_large-height":339,large:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F4-1600x705.jpg","large-width":M,"large-height":705,carousel:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F4-750x500.jpg","carousel-width":B,"carousel-height":l,wide:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F4-1500x500.jpg","wide-width":P,"wide-height":l,standart:"https:\u002F\u00