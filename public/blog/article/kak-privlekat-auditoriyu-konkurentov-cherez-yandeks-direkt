a,expert:b}]},{acf_fc_layout:S,type:ad,photos:[{ID:auW,id:auW,title:"8",filename:"8.jpg",url:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8.jpg",alt:a,author:u,description:a,caption:a,name:"8-2",date:"2018-11-30 14:30:14",modified:"2018-11-30 14:30:20",mime_type:K,type:v,icon:w,width:1701,height:1269,sizes:{thumbnail:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-300x300.jpg","thumbnail-width":h,"thumbnail-height":h,medium:auX,"medium-width":k,"medium-height":nw,medium_large:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-768x573.jpg","medium_large-width":z,"medium_large-height":hs,large:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-1600x1194.jpg","large-width":M,"large-height":1194,carousel:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-750x500.jpg","carousel-width":B,"carousel-height":l,wide:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-1500x500.jpg","wide-width":P,"wide-height":l,standart:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-1200x895.jpg","standart-width":F,"standart-height":895,"thumb-x2":"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-600x600.jpg","thumb-x2-width":i,"thumb-x2-height":i,case:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-450x336.jpg","case-width":y,"case-height":336,case2x:auX,"case2x-width":k,"case2x-height":nw,caseBig:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-650x485.jpg","caseBig-width":t,"caseBig-height":485,caseBig2x:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-1300x970.jpg","caseBig2x-width":J,"caseBig2x-height":afA,blog:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-660x492.jpg","blog-width":x,"blog-height":aug,blog2x:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F8-1320x985.jpg","blog2x-width":N,"blog2x-height":985}}]},{acf_fc_layout:c,section_title:hg,content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp class=\"article_decoration_first\"\u003EФирменный стиль X Clinic заложил фундамент бренда. Мы создали целостный образ компании в глазах владельца бизнеса и инвесторов, который они могут начать транслировать вместе с запуском клиники.\u003C\u002Fp\u003E\n\u003Cp\u003EДля российского рынка спа-отелей, курортных клиник и санаториев стиль уникален — благодаря этому мы заранее отстроились от конкурентов.\u003C\u002Fp\u003E\n\u003Cp class=\" article_decoration_last\"\u003EСамое главное — мы показали отличия клиники. Поэтому ее аудитория легко запомнит и сможет ассоциировать интегративную медицину с нашими визуальными образами.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]}],tags:{case:r},term:p,read_also:[{title:bu,slug:bv,background:bw,type:d,type_slug:f},{title:gL,slug:gM,background:gN,type:r,type_slug:p}],embed:g,meta_title:"Фирменный стиль для X Clinic — Статья — Serenity",meta_description:t$,meta_image:t_},"analitika-dlya-kliniki-kompozit":{title:ck,slug:cH,description:aif,background:{url:ahU,sizes:{thumbnail:ahV,medium:ahW,medium_large:ahX,large:wW,carousel:ahY,wide:cI,standart:ahZ,"thumb-x2":ah_,case:ah$,case2x:aia,caseBig:aib,caseBig2x:aic,blog:aid,blog2x:aie}},author:{expert:{name:j,role:e,image:b},text:a},date:dJ,content:[{acf_fc_layout:c,section_title:a,content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp class=\"article_decoration_first\"\u003EНедавно за счёт комплексного маркетинга мы достигли ROMI 476% для клиники пластической хирургии «Композит». Это во многом благодаря аналитике — мы видим, какие маркетинговые действия приводят клиентов, и можем менять стратегию.\u003C\u002Fp\u003E\n\u003Cp class=\" article_decoration_last\"\u003EЭдуард — специалист по рекламе и лидер направления аналитики, рассказал, как мы измеряем эффективность рекламы, контент-маркетинга, SEO и операторов колл-центра клиники.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"Проблемы на старте",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp class=\"article_decoration_first article_decoration_last\"\u003EГлавная проблема: не было достоверной статистики по обращениям клиентов в клинику и не отслеживались звонки. Поэтому когда мы запускали рекламные кампании и контент-маркетинг, пришлось отталкиваться от тех немногочисленных данных, что были в Яндекс. Метрике и Google Analytics.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-326\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-850x900.jpg\" alt=\"\" width=\"850\" height=\"900\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-850x900.jpg 850w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-425x450.jpg 425w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-614x650.jpg 614w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-1228x1300.jpg 1228w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-623x660.jpg 623w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-1247x1320.jpg 1247w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-768x813.jpg 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-1511x1600.jpg 1511w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-1134x1200.jpg 1134w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-227x240.jpg 227w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-453x480.jpg 453w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-331x350.jpg 331w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-661x700.jpg 661w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos-283x300.jpg 283w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FcW9RV54Qbos.jpg 1554w\" sizes=\"(max-width: 850px) 100vw, 850px\" \u002F\u003E\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"Система аналитики",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EМы используем связку из систем аналитики (Google Analytics и Яндекс. Метрика), сервиса коллтрекинга от CoMagic, базы данных BigQuery и визуализируем информацию в Power BI. Дополнительно используем Key Collector, чтобы определять сезонность услуг.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"Коллтрекинг",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-327\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-900x519.jpg\" alt=\"\" width=\"900\" height=\"519\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-900x519.jpg 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-450x259.jpg 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-650x375.jpg 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-1300x750.jpg 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-768x443.jpg 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-1600x923.jpg 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-1200x692.jpg 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-660x381.jpg 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-1320x761.jpg 1320w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-416x240.jpg 416w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-833x480.jpg 833w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-607x350.jpg 607w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-1214x700.jpg 1214w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FyqN9wovLLAc-300x173.jpg 300w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n\u003Cp class=\"article_decoration_first\"\u003EДля коллтрекинга мы используем CoMagic. Это на наш взгляд самый удобный, понятный и простой сервис для отслеживания звонков. Маркетолог тегирует звонки, чтобы потом передавать информацию о них в динамические отчёты в Power BI . То есть, мы видим не только их количество, но и полезную информацию о них: эффективность операторов колл-центра, частые вопросы и возражения пациентов.\u003C\u002Fp\u003E\n\u003Cp class=\" article_decoration_last\"\u003EДля контекстной рекламы мы используем динамический коллтрекинг, а для контент-маркетинга и SEO — статический.\u003C\u002Fp\u003E\n\u003Cul class=\"article_decoration_first\"\u003E\n\u003Cli\u003EДинамический коллтрекинг позволяет видеть, какая кампания или ключевое слово приводят к конверсиям и записям.\u003C\u002Fli\u003E\n\u003C\u002Ful\u003E\n\u003Cul class=\" article_decoration_last\"\u003E\n\u003Cli\u003EСо статическим коллтрекингом мы видим только каналы: человек пришёл из ВК, Facebook, Instagram или из поисковой выдачи.\u003C\u002Fli\u003E\n\u003C\u002Ful\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"База данных",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp class=\"article_decoration_first\"\u003EМы используем BigQuery для хранения данных из систем аналитики и коллтрекинга. Это база данных от Google, которая работает на MySQL. Благодаря BigQuery у нас огромное хранилище для данных с быстрым доступом к ним.\u003C\u002Fp\u003E\n\u003Cp class=\" article_decoration_last\"\u003EВ BQ мы выгружаем сырые данные без потери конверсий и прочих важных метрик с помощью языка программирования R. Это легче и быстрее, чем если бы мы подключались напрямую к Google Ads, Яндекс. Метрике и другим сервисам. Это также позволяет обходить ограничения рекламных и аналитических сервисов по выгрузке данных. Далее эти данные попадают в автообновляемые дашборды Power BI.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"Динамические отчёты",content_repeater:[{block_subtitle:a,is_note:m,text_block:"\u003Cp class=\"article_decoration_first article_decoration_last article_decoration_before\"\u003EДля вывода и визуализации данных мы используем Power BI. Отчёты в нём удобно показывать клиенту, вся информация отображается наглядно, есть быстрый доступ к любому срезу данных. Во внутренних дашбордах мы видим, из каких рекламных кампаний люди просто оставляют заявку на сайте, а из каких — записываются на приём:\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-328\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-900x367.jpg\" alt=\"\" width=\"900\" height=\"367\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-900x367.jpg 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-768x313.jpg 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-1600x652.jpg 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-1200x489.jpg 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-450x183.jpg 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-650x265.jpg 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-1300x530.jpg 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-660x269.jpg 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-1320x538.jpg 1320w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FoMc9r4M8o1U-300x122.jpg 300w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n",note_counter:a,note:auY,expert:b},{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EВо внутренних отчетах Power BI мы видим и многоканальные конверсии — все касания человека с рекламой, сайтом или нашими соцсетями до того, как он обратился в клинику. Благодаря этому корректируем рекламные кампании и снижаем стоимость заявки.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-329\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-900x508.jpg\" alt=\"\" width=\"900\" height=\"508\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-900x508.jpg 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-450x254.jpg 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-650x367.jpg 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-1300x733.jpg 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-768x433.jpg 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-1600x903.jpg 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-1200x677.jpg 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-660x372.jpg 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-1320x745.jpg 1320w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-425x240.jpg 425w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-851x480.jpg 851w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-620x350.jpg 620w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-1241x700.jpg 1241w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002F2qiE22Spslg-300x169.jpg 300w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n\u003Cp\u003EНа этих графиках видим, как коррелируют заявки и записи на приём в разрезах источников клиентов: контекстная реклама, контент-маркетинг, SEO. Это позволяет оценивать качество обращений и то, как стоимость лида записи зависит от этого качества.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"Сезонность",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp class=\"article_decoration_first\"\u003EЕщё на этапе брифа с клиентом узнали, что на разные операции спрос падает и уменьшается с учётом времени года. Чтобы точно определить сезонность, взяли семантику для каждой из услуг клиники и запустили парсинг частотности запросов через Key Collector. Теперь знаем точно, какие услуги продвигать в разное время года.\u003C\u002Fp\u003E\n",note_counter:a,note:auY,expert:b},{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EМы постоянно улучшаем маркетинг «Композита». Систему аналитики — в том числе. Будем держать вас в курсе и рассказывать о нововведениях и их результатах.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]}],tags:{case:r},term:p,read_also:[{title:ah,slug:ai,background:aj,type:d,type_slug:f},{title:bo,slug:bp,background:bq,type:r,type_slug:p}],embed:g,meta_title:"Аналитика для клиники «Композит» — Статья — Serenity",meta_description:ck,meta_image:wW},"kejs-kontent-marketing-dlya-kliniki-plasticheskoj-hirurgii-kompozit":{title:bo,slug:bp,description:uj,background:{url:gp,sizes:{thumbnail:TJ,medium:kH,medium_large:TK,large:gp,carousel:TL,wide:bq,standart:TM,"thumb-x2":TN,case:TO,case2x:kH,caseBig:TP,caseBig2x:TQ,blog:TR,blog2x:TS}},author:{expert:{name:nr,role:eM,image:ns},text:a},date:dJ,content:[{acf_fc_layout:c,section_title:a,content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp class=\"_article_paragraph article_paragraph\"\u003E\u003Cstrong\u003EЗадачи\u003Cbr \u002F\u003E\n\u003C\u002Fstrong\u003EВыделиться на фоне конкурентов в социальных сетях, укрепить знания о пластической хирургии среди пользователей и увеличить количество обращений в клинику.\u003C\u002Fp\u003E\n\u003Cp class=\"_article_paragraph article_paragraph article_decoration_last\"\u003E\u003Cstrong\u003EРешение\u003Cbr \u002F\u003E\n\u003C\u002Fstrong\u003EСоздали стратегию, наладили создание контента и наладили его рекламу в социальных сетях.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"1. Создание стратегии",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp class=\"_article_paragraph article_paragraph article_decoration_first\"\u003E\u003Cstrong\u003EПроанализировали конкурентов.\u003C\u002Fstrong\u003E Выяснили, что в социальных сетях много сообществ клиник пластической хирургии, но с некачественным контентом: отталкивающие изображения, отсутствие смысла и пользы в текстах. Email-рассылку и блог на сайте никто не вёл. Также заметили, что конкуренты не промоутируют посты в социальных сетях.\u003C\u002Fp\u003E\n\u003Cp class=\"_article_paragraph article_paragraph\"\u003EЭто дало нам точки роста — чтобы выделиться на фоне конкурентов, необходимо создавать полезный, интересный контент и промоутировать его на целевую аудиторию.\u003C\u002Fp\u003E\n\u003Cp class=\"_article_paragraph article_paragraph\"\u003EНа этапе формирования стратегии выбрали основные каналы продвижения, сформулировали позиционирование, обозначили рубрики контента.\u003C\u002Fp\u003E\n\u003Cp class=\"_article_paragraph article_paragraph article_decoration_last\"\u003E\u003Cstrong\u003EПроанализировали аудиторию. \u003C\u002Fstrong\u003EВыделили аватары покупателей услуг клиники пластической хирургии. Основные сегменты аудиторий разделили по направлениям:\u003C\u002Fp\u003E\n\u003Cul class=\"_article_paragraph article_paragraph article_decoration_first article_decoration_last\"\u003E\n\u003Cli\u003Eженщины от 25 до 35 лет — коррекция фигуры после родов;\u003C\u002Fli\u003E\n\u003Cli\u003Eдевушки до 30 лет — увеличение груди, ринопластика;\u003C\u002Fli\u003E\n\u003Cli\u003Eженщины от 40 лет — возрастные операции.\u003C\u002Fli\u003E\n\u003C\u002Ful\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"2. Создание контента",content_repeater:[{block_subtitle:a,is_note:m,text_block:"\u003Cp\u003EСначала создали дизайн-систему для социальных сетей, единую с оформлением бренда и рекламными баннерами. Затем начали делать полезный контент и взаимодействовать с пользователями.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:aqe,is_note:b,text_block:"\u003Cp\u003EОформили группы в социальных сетях и наполнили сообщества первичным контентом. Чтобы укрепить среди аудитории знания о пластической хирургии, мы использовали ассоциации на изображениях.\u003C\u002Fp\u003E\n\u003Cp\u003EОформили группы в социальных сетях и наполнили сообщества первичным контентом. Чтобы укрепить среди аудитории знания о пластической хирургии, мы использовали ассоциации на изображениях.\u003C\u002Fp\u003E\n\u003Cp\u003EМы удерживаем внимание пользователя и заставляем его задуматься: почему именно эта картинка стала иллюстрацией и как она связана с заголовком. И заодно выделяемся на фоне конкурентов нетипичным визуальным рядом.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-full wp-image-1092\" src=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1.jpg\" alt=\"\" width=\"807\" height=\"807\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1.jpg 807w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1-450x450.jpg 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1-650x650.jpg 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1-660x660.jpg 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1-300x300.jpg 300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1-768x768.jpg 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1-600x600.jpg 600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1-480x480.jpg 480w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1-700x700.jpg 700w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1-240x240.jpg 240w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FnAGlvR0-TQ-1-350x350.jpg 350w\" sizes=\"(max-width: 807px) 100vw, 807px\" \u002F\u003E\u003C\u002Fp\u003E\n\u003Cp\u003E&nbsp;\u003C\u002Fp\u003E\n\u003Cp\u003EПри выборе пластического хирурга пациент уделяет внимание отзывам и фотографиям результатов. Мы скрыли неэстетичные изображения в ленте с помощью карусели с графическими заглушками. Это помогает нам вести ленту Instagram в едином стиле и не шокировать аудиторию фотографиями:\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-full wp-image-1093\" src=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FtbQhgoQC1o0-1.jpg\" alt=\"\" width=\"638\" height=\"638\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FtbQhgoQC1o0-1.jpg 638w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FtbQhgoQC1o0-1-450x450.jpg 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FtbQhgoQC1o0-1-300x300.jpg 300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FtbQhgoQC1o0-1-600x600.jpg 600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FtbQhgoQC1o0-1-480x480.jpg 480w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FtbQhgoQC1o0-1-350x350.jpg 350w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FtbQhgoQC1o0-1-240x240.jpg 240w\" sizes=\"(max-width: 638px) 100vw, 638px\" \u002F\u003E\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:apZ,is_note:b,text_block:"\u003Cp class=\"_article_paragraph article_paragraph article_decoration_first article_decoration_last article_decoration_before\"\u003EВ Facebook, ВКонтакте, Instagram и Одноклассниках мы рассказываем об операциях и их подготовке, о команде клиники — показываем, что хирурги не только профессионалы, но и люди, для которых важна эмоциональная связь с пациентами; отвечаем на вопросы.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-321\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-900x589.jpg\" alt=\"\" width=\"900\" height=\"589\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-900x589.jpg 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-450x295.jpg 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-650x425.jpg 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-1300x851.jpg 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-768x503.jpg 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-1600x1047.jpg 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-1200x785.jpg 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-660x432.jpg 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-1320x864.jpg 1320w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-367x240.jpg 367w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-733x480.jpg 733w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-535x350.jpg 535w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-1070x700.jpg 1070w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FUONTulGw6ek-300x196.jpg 300w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:"Модерация",is_note:b,text_block:"\u003Cp\u003EКогда человек задумывается об операции, он ищет много информации, взвешивает все за и против. Срок от мысли об операции до консультации у врача может быть несколько лет и столько же от консультации до операции. Поэтому важно быстро отвечать на комментарии и сообщения людей, ведь так больше шансов, что он обратится именно в нашу клинику.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:ak,expert:{name:nr,role:eM,image:ns},l_size:m,text:"\u003Cp\u003EНедавно в сообщениях в Instagram обратилась женщина с вопросом, есть ли у клиники программы для пенсионеров. Мы уточнили вопрос у руководства — программ не было, но вместо этого предложили посетить бесплатную консультацию и оформить кредит на операцию. Через 10 минут она позвонила и записалась на приём.\u003C\u002Fp\u003E\n"},{acf_fc_layout:c,section_title:a,content_repeater:[{block_subtitle:nd,is_note:b,text_block:"\u003Cp\u003EКогда мы делали контент-маркетинговую стратегию, выделили основные сегменты аудиторий и создали карту мыслей с местами, в которых сможем найти покупателей.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-322\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-900x589.jpg\" alt=\"\" width=\"900\" height=\"589\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-900x589.jpg 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-450x294.jpg 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-650x425.jpg 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-1300x851.jpg 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-768x502.jpg 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-1600x1047.jpg 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-1200x785.jpg 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-660x432.jpg 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-1320x864.jpg 1320w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-367x240.jpg 367w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-734x480.jpg 734w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-535x350.jpg 535w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-1070x700.jpg 1070w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FeB_ZzmiBwrw-300x196.jpg 300w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n\u003Cp\u003EНа базе карты собрали группы аудиторий для каждой соцсети. Для ВК и Одноклассников — это участники сообществ конкурентов, пабликов о пластической хирургии, групп молодых мам и страдающих лишним весом. Для Facebook и Instagram — люди, интересующиеся пластикой. С помощью пикселей ретаргетинга запустили рекламу на тех, кто заходил на сайт «Композита».\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EЗапустили объявления разных форматов: тизеры, посты с кнопками, карусели, скрытые и открытые посты в сообществах. Протестировали каждую аудиторию и выделили самые эффективные, на которые постоянно показываем рекламу.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:eO,content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp class=\"_article_paragraph article_paragraph article_decoration_first article_decoration_last\"\u003EНесмотря на то, что мы запускались в период сезонного спада, за полгода сотрудничества пришли к следующим результатам по контент-маркетингу:\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:O,quote_text:"Увеличение количества заявок на 75%,\u003Cbr \u002F\u003E\r\nснижение стоимости обращения в 2 раза,\u003Cbr \u002F\u003E\r\nснижение стоимости записи в 4 раза. "},{acf_fc_layout:c,section_title:a,content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp class=\"_article_paragraph article_paragraph article_decoration_first article_decoration_last\"\u003EВ августе нам удалось выровнять стоимость заявки из каналов контент-маркетинга с контекстной рекламой: стоимость заявки из соцсетей на 90 рублей выше, а записи на прием на 700 рублей дешевле.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]}],tags:{case:r},term:p,read_also:[{title:ah,slug:ai,background:aj,type:d,type_slug:f},{title:aL,slug:aM,background:aN,type:r,type_slug:p}],embed:g,meta_title:"Контент-маркетинг для клиники «Композит» — Статья — Serenity",meta_description:uj,meta_image:gp},"kejs-kak-uvelichit-tselevoj-trafik-pochti-v-4-raza-blagodarya-seo":{title:br,slug:bs,description:uk,background:{url:gq,sizes:{thumbnail:TU,medium:kI,medium_large:TV,large:gq,carousel:TW,wide:bt,standart:TX,"thumb-x2":TY,case:TZ,case2x:kI,caseBig:T_,caseBig2x:T$,blog:Ua,blog2x:Ub}},author:{expert:{name:j,role:e,image:b},text:a},date:dJ,content:[{acf_fc_layout:c,section_title:a,content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EAddrea — поставщик интерактивного оборудования для наружной рекламы и разработчик в сфере Digital Signage. Рассказываем, каких результатов мы достигли в продвижении этой компании благодаря оптимизации сайта для поисковых систем.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EЗадача.\u003C\u002Fstrong\u003E На сайте клиента было крайне мало посетителей. Ставили цель привлечь целевой трафик и увеличить конверсию в обращения.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"Анализ конкурентов",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EПеред началом основных работ изучили успешных ко