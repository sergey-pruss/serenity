wp-content\u002Fuploads\u002F2019\u002F01\u002FIMG_9255-1200x433.jpg","standart-width":F,"standart-height":bd,"thumb-x2":"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FIMG_9255-600x600.jpg","thumb-x2-width":i,"thumb-x2-height":i,case:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FIMG_9255-450x162.jpg","case-width":y,"case-height":162,case2x:atD,"case2x-width":k,"case2x-height":zq,caseBig:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FIMG_9255-650x235.jpg","caseBig-width":t,"caseBig-height":235,caseBig2x:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FIMG_9255-1300x469.jpg","caseBig2x-width":J,"caseBig2x-height":no,blog:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FIMG_9255-660x238.jpg","blog-width":x,"blog-height":238,blog2x:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FIMG_9255-1320x476.jpg","blog2x-width":N,"blog2x-height":476}}]},{acf_fc_layout:ak,expert:{name:iC,role:iD,image:zg},l_size:m,text:"\u003Cp\u003EЖурнальный разворот в мудборде на съемку команды — направляющая, которая помогает сделать качественную работу, даже если бюджет ограничен, как это было в нашем случае.\u003C\u002Fp\u003E\n"},{acf_fc_layout:c,section_title:"Подготовка к реализации",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EОсновательная подготовка к съемке помогает сократить расстояние между ожиданием и реальностью, поэтому важно тщательно спланировать каждый этап.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003E\u003Cbr \u002F\u003E\nКоманда.\u003C\u002Fstrong\u003E Грамотный кастинг съемочной команды поможет реализовать любую идею и пережить самый суровый тайминг. Так например, собранной мной команде достался мощный челлендж — преобразить и отснять 27 человек за 8 часов. И мы справились!\u003C\u002Fp\u003E\n\u003Cp\u003E&nbsp;\u003C\u002Fp\u003E\n\u003Cblockquote\u003E\u003Cp\u003E\u003Cem\u003EПрофессионалы в своем деле — это настоящая поддержка и опора на протяжении всей съемки.\u003C\u002Fem\u003E\u003C\u002Fp\u003E\n\u003Cp\u003E&nbsp;\u003C\u002Fp\u003E\u003C\u002Fblockquote\u003E\n\u003Cp\u003E\u003Cstrong\u003EЛокация.\u003C\u002Fstrong\u003E Для успешной съемки недостаточно найти красивый интерьер или пейзаж. Важно убедиться в том, что все именно так, как вы представляете: необходимый инвентарь на месте, оборудование исправно, а размер помещения подходит под задачу.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EОбразы.\u003C\u002Fstrong\u003E На групповой съемке важно не только подобрать красивую одежду для каждого, но и продумать сочетание костюмов между собой: в стилистике, цветовой гамме или общей детали.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EТехническое задание.\u003C\u002Fstrong\u003E Чтобы задумка воплотилась в жизнь нужно подробно описать цели съемки и условия подготовки, необходимое качество и количество снимков,пожелания по цветокоррекции, ретуши и монтажу.\u003C\u002Fp\u003E\n\u003Cp\u003E&nbsp;\u003C\u002Fp\u003E\n\u003Cp\u003EЧтобы все прошло хорошо, мы постарались учесть все:\u003C\u002Fp\u003E\n\u003Cul\u003E\n\u003Cli\u003EФотограф заранее подготовила раскадровки — поэкспериментировала с эскизами и определила, как кто встанет.\u003C\u002Fli\u003E\n\u003Cli\u003EВизажист и мастер по волосам рассчитали работу до минут — заранее узнали о длине волос и типаже каждого участника, определили сложность макияжа для девушек, выбрали себе ассистентов.\u003C\u002Fli\u003E\n\u003Cli\u003EКоманда настроилась. Я преподнесла мероприятие, как корпоративную тусовку, куда нужно принести только хорошее настроение. Остальное съемочная команда взяли на себя.\u003C\u002Fli\u003E\n\u003C\u002Ful\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"Организация процесса",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EСправиться со съемкой в экстремально сжатые сроки помогает тайм-менеджмент и грамотная логистика — подробное расписание процессов и перемещений. Из-за большого количества человек на съемке, было важно расписать день буквально по часам и минутам.\u003C\u002Fp\u003E\n\u003Cp\u003E&nbsp;\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone wp-image-1123\" src=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002Fcndjs-900x573.jpg\" alt=\"\" width=\"612\" height=\"411\" \u002F\u003E\u003C\u002Fp\u003E\n\u003Cp\u003E&nbsp;\u003C\u002Fp\u003E\n\u003Cp\u003EОтдельную сложность создала стилизация. Для съемки было куплено 27 полноценных комплектов одежды — более 100 позиций на общую сумму 256 000 ₽. Требовалось продумать способ доставки до студии и возврата.\u003C\u002Fp\u003E\n\u003Cp\u003E&nbsp;\u003C\u002Fp\u003E\n\u003Cblockquote\u003E\u003Cp\u003E\u003Cem\u003EИз пятилетнего опыта организации творческих съемок я хорошо запомнила лайфхак «купи-сфотографируй-сдай \u003C\u002Fem\u003E\u003Cem\u003Eв идеальном состоянии», однако сумма покупки заставила принять на себя возможный риск. Финал у этой истории хороший — магазин принял возврат без проблем.\u003C\u002Fem\u003E\u003C\u002Fp\u003E\u003C\u002Fblockquote\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"День X — реализация",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EБлагодаря подготовке все прошло отлично. Без спешки и аврала. Расписание помогло оперативно перераспределить занятость участником и выйти из ситуации без финансовых и эмоциональных потерь.\u003C\u002Fp\u003E\n\u003Cp\u003E&nbsp;\u003C\u002Fp\u003E\n\u003Cul\u003E\n\u003Cli\u003E\u003Cb\u003EФотограф \u003C\u002Fb\u003Eуже знала, как расставить ребят, веселила и помогала комфортно чувствовать себя перед камерой.\u003C\u002Fli\u003E\n\u003Cli\u003E\u003Cb\u003EВизажист и мастер по волосам \u003C\u002Fb\u003Eграмотно организовали процесс своей работы: подобрали ассистентов и освободили себе время на сложные элементы в образах.\u003C\u002Fli\u003E\n\u003Cli\u003E\u003Cb\u003EСтилист \u003C\u002Fb\u003Eзаранее подготовила костюмы и могла в них ориентироваться. Это помогло в тех случаях, когда оказывалось, что тот или иной костюм не подходит. Несмотря на опрос относительно размеров, такое все же случалось.\u003C\u002Fli\u003E\n\u003C\u002Ful\u003E\n\u003Cp\u003E&nbsp;\u003C\u002Fp\u003E\n\u003Cp\u003EВ итоге день съемки прошел легко и непринужденно. Однако без четкой организации все могло перевернуться с ног на голову еще до начала — не учла, что администратора в студию для раннего открытия нужно вызывать заранее.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:S,type:as,photos:[{ID:atE,id:atE,title:"IMG_1921",filename:"IMG_1921.jpg",url:nu,alt:a,author:u,description:a,caption:a,name:"img_1921",date:"2019-01-28 10:18:27",modified:"2019-01-28 10:18:34",mime_type:K,type:v,icon:w,width:ay,height:bB,sizes:{thumbnail:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FIMG_1921-300x300.jpg","thumbnail-width":h,"thumbnail-height":h,medium:zr,"medium-width":cs,"medium-height":k,medium_large:nu,"medium_large-width":ay,"medium_large-height":bB,large:nu,"large-width":ay,"large-height":bB,carousel:atF,"carousel-width":ay,"carousel-height":l,wide:atF,"wide-width":ay,"wide-height":l,standart:nu,"standart-width":ay,"standart-height":bB,"thumb-x2":"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FIMG_1921-600x600.jpg","thumb-x2-width":i,"thumb-x2-height":i,case:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FIMG_1921-338x450.jpg","case-width":atG,"case-height":y,case2x:zr,"case2x-width":cs,"case2x-height":k,caseBig:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FIM