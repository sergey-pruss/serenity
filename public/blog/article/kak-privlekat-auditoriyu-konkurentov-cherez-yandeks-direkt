0x600.jpg","thumb-x2-width":i,"thumb-x2-height":i,case:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F05\u002F1CKedIYAKqY-450x300.jpg","case-width":y,"case-height":h,case2x:asu,"case2x-width":k,"case2x-height":i,caseBig:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F05\u002F1CKedIYAKqY-650x433.jpg","caseBig-width":t,"caseBig-height":bd,caseBig2x:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F05\u002F1CKedIYAKqY-1050x700.jpg","caseBig2x-width":bY,"caseBig2x-height":U,blog:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F05\u002F1CKedIYAKqY-660x440.jpg","blog-width":x,"blog-height":aC,blog2x:yQ,"blog2x-width":Q,"blog2x-height":Y}}]},{acf_fc_layout:c,section_title:a,content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EПриятные люди и полезная информация полностью оправдали мои ожидания. Это был мой следующий шаг по карте CJM.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EОбщение посредством обучения\u003C\u002Fstrong\u003E —  экспертность и знания, которыми вы делитесь с аудиторией. Знания распространяются через online-курсы, блоги, выпуск дайджестов и книг. Здесь действует принцип Win-Win. Клиенты получают эксклюзивные знания, а компании общаются и делятся с аудиторией знаниями, монетизируя это.\u003C\u002Fp\u003E\n",note_counter:a,note:asv,expert:b}]},{acf_fc_layout:c,section_title:"HR-брендинг",content_repeater:[{block_subtitle:a,is_note:m,text_block:"\u003Cp\u003EПод впечатлениями от Digitale и локального семинара я увидел на сайте HeadHunter объявление о поиске стажеров на вакансию маркетолог проектов в Serenity и откликнулся на него.\u003C\u002Fp\u003E\n\u003Cp\u003EЯ очень ждал ответа на отклик и, наконец, получил приглашение на собеседование с директором компании Сергеем Пруссом. Ценности Serenity, о которых рассказал Сергей, полностью соответствовали моим.\u003C\u002Fp\u003E\n\u003Cp\u003EПосле собеседования я получил тестовое задание, хорошо его выполнил и меня пригласили на стажировку. На стажировке, я больше узнал о корпоративной культуре, ценностях и линейной структуре Serenity. Так в игру вступил HR-брендинг.\u003C\u002Fp\u003E\n",note_counter:a,note:asv,expert:b}]},{acf_fc_layout:c,section_title:"Сейчас я работаю в Serenity больше года",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EВ моем потребительском случае воронка вовлечения была настроена так, что управляла моим опытом в разных точках касания с Serenity. Компания всегда транслировала ключевые ценности и качества (ответственность, свобода, упорство). Сейчас я работаю в компании полтора года и мы занимаемся построением таких дорожных карт для наших клиентов.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-1547\" src=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-900x644.png\" alt=\"\" width=\"900\" height=\"644\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-900x644.png 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-450x322.png 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-650x465.png 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-1300x931.png 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-660x473.png 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-1320x945.png 1320w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-768x550.png 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-1600x1146.png 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-1200x859.png 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-335x240.png 335w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-670x480.png 670w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-489x350.png 489w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-978x700.png 978w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-628x450.png 628w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F04\u002FRoad-1257x900.png 1257w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n\u003Cp\u003EЕсли вы хотите создать собственную Customer Journey Map, внимательно слушайте клиентов и наблюдайте за ними. Поступки людей, пути взаимодействия с продуктом, их отношение к нему — важно все.\u003C\u002Fp\u003E\n\u003Cp\u003EКомплексный мэппинг путешествия клиентов и соискателей — залог роста бизнеса, основанного на реальных данных. Проверено мной.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]}],tags:{article:d},term:s,read_also:[{title:gI,slug:gJ,background:gK,type:d,type_slug:f},{title:vV,slug:vW,background:vY,type:o,type_slug:s}],embed:g,meta_title:"CJM: путь от знакомства до трудоустройства — Статья — Serenity",meta_description:"Что такое customer journey map? Приведем примеры карты cjm, коснемся cjm маркетинга, а также расскажем о customer journey map для сайтов и интернет магазинов.",meta_image:tv},"moderatsiya-kak-uvelichit-loyalnost-i-chislo-klientov":{title:aeZ,slug:ae_,description:afl,background:{url:ae$,sizes:{thumbnail:afa,medium:l$,medium_large:afb,large:wA,carousel:afc,wide:afd,standart:afe,"thumb-x2":aff,case:afg,case2x:l$,caseBig:afh,caseBig2x:afi,blog:afj,blog2x:afk}},author:{expert:{name:nr,role:eM,image:ns},text:a},date:afm,content:[{acf_fc_layout:c,section_title:"Представьте, что вы пришли в магазин...",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003E&#8230; чтобы купить стиральную машину. Тут же подходит продавец-консультант и предлагает варианты, которые могут вам подойти. Выбирает подходящие размеры, функционал, цену; отвечает на вопросы. Модерация — это тот же продавец-консультант, но в \u003Ca href=\"https:\u002F\u002Fserenity.agency\u002Fservices\u002Fcontent\"\u003Eсоциальных сетях\u003C\u002Fa\u003E.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:O,quote_text:"Работа модератора — это ответы на сообщения и комментарии клиентов."},{acf_fc_layout:c,section_title:"Как модерация влияет на бизнес",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EМодерация влияет на имидж и продажи компании, помогает выявить и нивелировать негатив.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EИмидж компании\u003C\u002Fstrong\u003E. В этом ключе модерация выступает как инструмент формирования лояльности клиента к компании. Часто это обработка негативных комментариев о компании — они могут снизить лояльность существующих клиентов и отпугнуть потенциальных. В такой ситуации важны скорость обработки ответа и повышение доверия клиента.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EВлияние на продажи\u003C\u002Fstrong\u003E. Потенциальный клиент задает вопросы в \u003Ca href=\"https:\u002F\u002Fserenity.agency\u002Fservices\u002Fsmm\"\u003Eсоциальных сетях\u003C\u002Fa\u003E с ожиданием, что его проконсультируют и подтолкнут к покупке. Здесь очень важны скорость обработки ответа, информативность и добавление открытых вопросов. Как в классических способах работы с клиентом и подведения его к продаже.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:"Как обрабатывать негатив",is_note:b,text_block:"\u003Cp\u003EОбработка негатива должна содержать в себе стратегию «+ – +». Обрабатывая негатив, мы начинаем коммуникацию плюсом:\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-1156\" src=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FFrame-1-900x307.png\" alt=\"\" width=\"900\" height=\"307\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FFrame-1-900x307.png 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FFrame-1-768x262.png 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FFrame-1-1600x545.png 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FFrame-1-1200x409.png 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FFrame-1-450x153.png 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FFrame-1-650x221.png 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FFrame-1-1300x443.png 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FFrame-1-660x225.png 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2019\u002F01\u002FFrame-1-1320x450.png 1320w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n",note_counter:eN,note:"операции мы продали с помощью простого общения",expert:b}]},{acf_fc_layout:O,quote_text:"Если видите, что человек настроен крайне негативно, действуйте аккуратно."},{acf_fc_layout:c,section_title:a,content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003E\u003Cstrong\u003EТролли.\u003C\u002Fstrong\u003E Если вы понимаете, что столкнулись с троллингом, а ваш бренд позиционирует себя как открытый, позитивный и неформальный — вежливо пошутите в ответ. Если вы считаете себя серьезными — удалите комментарий или проигнорируйте.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EНегативный опыт.\u003C\u002Fstrong\u003E Когда человек по объективным или не очень причинам недоволен вами, стоит оставить его в покое. Попробуйте максимально разобраться в ситуации, подождав какое-то время. Выпустите пост, в котором объясняете политику компании и свои действия в подобных случаях, но без упоминания конкретного человека.\u003C\u002Fp\u003E\n",note_counter:a,note:asw,expert:b}]},{acf_fc_layout:c,section_title:"Примеры из практики",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EУчитывайте особенности бизнеса. К примеру, у \u003Ca href=\"https:\u002F\u002Fserenity.agency\u002Fcase\u002Fkompozit\"\u003Eклиники пластической хирургии\u003C\u002Fa\u003E порог входа может достигать несколько лет, поэтому важно обрабатывать запрос оперативно и ненавязчиво.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:"Работа на продажи — вопросы по поводу операции",is_note:m,text_block:"\u003Cp\u003EВ личные сообщения клиники поступил вопрос от девушки по поводу операции. Мы ответили от лица клинки и записали на бесплатную консультацию хирурга. Мы поддерживали контакт с девушкой, пока она не пришла на консультацию: отвечали на дополнительные вопросы, сообщали цены, помогали подобрать врача и подходящее время для приема. В итоге — она сделала 2 операции в клинике.\u003C\u002Fp\u003E\n\u003Cp\u003EВозможно, если бы мы не отреагировали вовремя, пациентка ушла бы в другую клинику или отложила операцию еще на неопределенное время.\u003C\u002Fp\u003E\n",note_counter:"2 операции",note:"мы продали с помощью простого общения",expert:b},{block_subtitle:"Работа на бренд — поиск решения проблемы клиента",is_note:m,text_block:"\u003Cp\u003EДля ответов на вопросы мы консультируемся с администраторами клиники, которые знают стоимость и особенности операций. Но к сожалению, часто сталкиваемся с «автоматическими» ответами — они не решают проблему потенциального клиента.\u003C\u002Fp\u003E\n\u003Cp\u003EЖенщина спросила в личных сообщениях сообщества о том, какие программы лояльности есть для пенсионеров. Ответ администратора: «У нас таких программ нет». Мы решили не отвечать так и поискать варианты решения проблемы, а не терять потенциального клиента.\u003C\u002Fp\u003E\n\u003Cp\u003EВместо программ лояльности предложили акции: бесплатная консультация у хирурга и возможность сделать операцию в кредит.\u003C\u002Fp\u003E\n",note_counter:a,note:"«Вместо программ лояльности предложили акции: бесплатная консультация у хирурга и возможность сделать операцию в кредит»",expert:{name:nr,role:eM,image:ns}}]},{acf_fc_layout:O,quote_text:"Через несколько минут женщина позвонила и записалась на консультацию. Может, она и не совершит покупку, но явно станет лучше относиться к клинике. А значит — и порекомендует знакомым."},{acf_fc_layout:c,section_title:"Напоследок — о тоне общения",content_repeater:[{block_subtitle:a,is_note:m,text_block:"\u003Cp\u003EПомимо содержания важна манера общения. Она задается на этапе формирования редакционной политики и должна быть выдержана в любых коммуникациях бренда.\u003C\u002Fp\u003E\n\u003Cp\u003EОбратите внимание, что «голос» бренда одинаковый как в наружной рекламе, так и в соцсетях или на сайте:\u003C\u002Fp\u003E\n",note_counter:a,note:asw,expert:b}]},{acf_fc_layout:O,quote_text:"Не должно быть такого, что в одной коммуникации обращение к потенциальному покупателю происходит на «вы», а в другой на «ты». Это портит впечатление о бренде."},{acf_fc_layout:c,section_title:"Что важно запомнить",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003E\u003Cstrong\u003EМодерация в социальных сетях — это продавец-консультант,\u003C\u002Fstrong\u003E который помогает клиенту решить проблему, найти подходящее решение и продает товар.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EВыбирайте тональность общения.\u003C\u002Fstrong\u003E В зависимости от типа бренда и стратегии присутствия в социальных сетях выбирайте, общаться с ними на «вы» или на «ты», с крайним уважением или по-приятельски.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EРешают быстрота реакции, четкость ответа на вопрос и уровень решения проблемы.\u003C\u002Fstrong\u003E\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]}],tags:{article:d},term:f,read_also:[{title:bo,slug:bp,background:bq,type:r,type_slug:p},{title:cJ,slug:cK,background:cL,type:d,type_slug:f}],embed:g,meta_title:"Модерация: как увеличить лояльность и число клиентов — Статья — Serenity",meta_description:"Статья о преимуществах модерации в социальных сетях, в инстаграм, ответов и модерации отзывов, комментариев и материалов.",meta_image:wA},"lidformy-kak-uvelichit-obem-zayavok-iz-facebook-i-instagram":{title:gI,slug:gJ,description:ahr,background:{url:ahg,sizes:{thumbnail:ahh,medium:mk,medium_large:ahi,large:wR,carousel:ahj,wide:gK,standart:ahk,"thumb-x2":ahl,case:ahm,case2x:mk,caseBig:ahn,caseBig2x:aho,blog:ahp,blog2x:ahq}},author:{expert:{name:bg,role:az,image:bX},text:"Благодаря лид формам клиенты могут оставлять заявки, минуя сайт. Рассказываем, как работать с этим инструментом в Фейсбук и Инстаграм. И получать много заявок по низкой стоимости."},date:ahs,content:[{acf_fc_layout:c,section_title:"Чем формат отличается от других",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EЛид формы хороши тем, что Facebook оптимизирует их не по стоимости показа или клика, а по стоимости заявки. Поэтому вам не нужно проводить дополнительную аналитику — алгоритмы \u003Ca href=\"https:\u002F\u002Fserenity.agency\u002Fservices\u002Fsmm\"\u003Eсоциальной сети\u003C\u002Fa\u003E сами ориентируют показ рекламы на увеличение прибыли.\u003C\u002Fp\u003E\n\u003Cp\u003EУ лид форм есть и другие плюсы:\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:"Нативность",is_note:b,t