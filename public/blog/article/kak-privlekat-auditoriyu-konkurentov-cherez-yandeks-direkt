Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F1-660x155.png 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F1-1320x311.png 1320w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:"Демотивируют, как ни странно, деньги",is_note:b,text_block:"\u003Cp\u003EЭто показали результаты исследований, описанные в книге. Чуть меньше демотивирует психологическое напряжение (давление руководства, дедлайны, строгие правила). А сильнее и денег, и напряжения — инерция, когда не происходит ничего нового и отсутствует стремление к достижениям.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:"А мотивирует больше всего игра",is_note:b,text_block:"\u003Cp\u003EЛюди играют в игры уже десятки тысяч лет — это эволюционно самый основной метод обучения и организации труда, который вдобавок развлекает. Чуть меньше мотивирует большая и классная цель. И еще чуть меньше — самореализация.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"Поэтому мы запустили игру",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EС апреля этого года наша команда соревнуется за титул «идеального серенитянина» — игра так и называется. Ей мы решили убить трех зайцев:\u003C\u002Fp\u003E\n\u003Col\u003E\n\u003Cli\u003Eоценивать каждого члена команды;\u003C\u002Fli\u003E\n\u003Cli\u003Eобратить внимание на ценности компании;\u003C\u002Fli\u003E\n\u003Cli\u003Eпоказать ориентир на ребят, которые соблюдают эти ценности и приносят крутые результаты.\u003C\u002Fli\u003E\n\u003C\u002Fol\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:ak,expert:{name:"Татьяна Дёмина",role:"HR и финансовый менеджер",image:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F10\u002FWpzO1DZg-600x600.jpeg"},l_size:m,text:"\u003Cp\u003E«Поначалу было очень много сомнений на этот счет, мы боялись, что игра создаст ненужную конкуренцию, которая может навредить нашей культуре. Мы стали размышлять, как можно преподнести игру не как соревнование на выживание в компании, а как толчок к развитию себя и своих навыков. Объяснили всем, зачем это нужно, что полезного можно вынести из игры и понадеялись на отзывчивость людей»\u003C\u002Fp\u003E\n"},{acf_fc_layout:c,section_title:"Учли три важных элемента",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-613\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-900x564.jpg\" alt=\"\" width=\"900\" height=\"564\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-900x564.jpg 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-450x282.jpg 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-650x407.jpg 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-1300x815.jpg 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-768x481.jpg 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-1600x1003.jpg 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-1200x752.jpg 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-660x414.jpg 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-1320x827.jpg 1320w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-383x240.jpg 383w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-766x480.jpg 766w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-559x350.jpg 559w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F2-1117x700.jpg 1117w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cb\u003EНаграда\u003C\u002Fb\u003E — 7% от квартальной прибыли, которые распределяются между семью лидерами квартала.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cb\u003EПобедитель\u003C\u002Fb\u003E — тот, кто набрал за год больше всего баллов. Его приз — это оплаченный компанией отпуск заграницу в конце года (трансфер, проживание).\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cb\u003EСоревнование идет по четырем критериям.\u003C\u002Fb\u003E Главный — доход сотрудника, ведь если он много зарабатывает, то много приносит и в бюджет компании — на окладе людей у нас нет. Еще сотрудника должны хорошо оценивать команда и руководство. Также если он делает публикации и выступает, то получает за это дополнительные баллы.\u003C\u002Fp\u003E\n\u003Cp\u003E&nbsp;\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-618\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-900x506.jpg\" alt=\"\" width=\"900\" height=\"506\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-900x506.jpg 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-450x253.jpg 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-650x366.jpg 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-1300x731.jpg 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-768x432.jpg 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-1600x900.jpg 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-1200x675.jpg 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-660x371.jpg 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-1320x743.jpg 1320w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-427x240.jpg 427w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-853x480.jpg 853w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-622x350.jpg 622w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F3-1244x700.jpg 1244w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n\u003Cp\u003EФормула расчета баллов проста: доход за квартал (+ баллы за публичную активность) умножается на среднюю оценку команды и среднюю оценку топ-менеджмента.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:"Как мы друг друга оцениваем",is_note:b,text_block:"\u003Cp\u003EДля этого написали небольшой сервис, с помощью которого автоматизировали оценку. Ребята могут оценивать друг друга по личным и профессиональным качествам, от своего лица или анонимно написать, что нравится и что можно улучшить.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-619\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-900x485.png\" alt=\"\" width=\"900\" height=\"485\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-900x485.png 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-450x242.png 450w, https: