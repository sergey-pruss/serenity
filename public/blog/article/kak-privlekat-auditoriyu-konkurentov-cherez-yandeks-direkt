Fuploads\u002F2018\u002F11\u002F2-660x287.jpg","blog-width":x,"blog-height":hz,blog2x:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F2-1320x574.jpg","blog2x-width":N,"blog2x-height":zG}}]},{acf_fc_layout:c,section_title:"Создание мудборда",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp class=\"article_decoration_first article_decoration_last\"\u003EПосле исследования мы накидываем идеи по визуализации своих представлений. В этом помогает мудборд.\u003C\u002Fp\u003E\n\u003Cblockquote\u003E\n\u003Cp class=\"article_decoration_first article_decoration_last\"\u003EМудборд — это подборка готовых цветовых решений, элементов дизайна и рисунков. С помощью него мы демонстрируем клиенту наше видение фирменного стиля.\u003C\u002Fp\u003E\n\u003C\u002Fblockquote\u003E\n\u003Cp class=\"article_decoration_first article_decoration_last article_decoration_before\"\u003EПри работе с мудбордом у заказчика появляются первые ассоциации, впечатления. По его обратной связи мы понимаем, что близко к стилю компании, а что нет. На это опирается дизайнер, когда разрабатывает логотип и другие элементы фирменного стиля.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:S,type:ad,photos:[{ID:aQ,id:aQ,title:a,filename:asP,url:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F3.jpg",alt:a,author:u,description:a,caption:"Мудборд для X Clinic",name:"3-2",date:"2018-11-30 14:23:48",modified:"2018-12-04 11:16:59",mime_type:K,type:v,icon:w,width:aqm,height:2100,sizes:{thumbnail:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F3-300x300.jpg","thumbnail-width":h,"thumbnail-height":h,medium:auN,"medium-width":auO,"medium-height":k,medium_large:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F11\u002F3-768x840.jpg","medium_large-width":z,"medium_large-height":840,large:"https:\u002