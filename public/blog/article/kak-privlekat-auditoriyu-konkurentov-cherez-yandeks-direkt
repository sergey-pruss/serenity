0x300.png","thumbnail-width":h,"thumbnail-height":h,medium:zx,"medium-width":zy,"medium-height":k,medium_large:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-1-768x1191.png","medium_large-width":z,"medium_large-height":1191,large:atZ,"large-width":hA,"large-height":at_,carousel:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-1-750x500.png","carousel-width":B,"carousel-height":l,wide:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-1-792x500.png","wide-width":hA,"wide-height":l,standart:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-1-774x1200.png","standart-width":774,"standart-height":F,"thumb-x2":"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-1-600x600.png","thumb-x2-width":i,"thumb-x2-height":i,case:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-1-290x450.png","case-width":290,"case-height":y,case2x:zx,"case2x-width":zy,"case2x-height":k,caseBig:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-1-419x650.png","caseBig-width":yY,"caseBig-height":t,caseBig2x:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-1-451x700.png","caseBig2x-width":451,"caseBig2x-height":U,blog:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F4-1-426x660.png","blog-width":426,"blog-height":x,blog2x:zx,"blog2x-width":zy,"blog2x-height":k}}]},{acf_fc_layout:c,section_title:a,content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003E\u003Cstrong\u003EО магазине можно оставлять отзывы. \u003C\u002Fstrong\u003EКлиент своевременно на них отвечал, а точки продаж получали высокие оценки пользователей. За счет этого и правильного заполнения филиалов «Мосплитка» стала показываться и на картах, и в поиске Яндекса по релевантным запросам.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-681\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F6-1-900x449.png\" alt=\"\" width=\"900\" height=\"449\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F6-1-900x449.png 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F6-1-768x383.png 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F6-1.png 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F6-1-1200x599.png 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F6-1-450x224.png 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F6-1-650x324.png 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F6-1-1300x648.png 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F6-1-660x329.png 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F6-1-1320x658.png 1320w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"Привели 60% заявок из Маркета",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EНа Яндекс.Маркет заходят люди, уже готовые купить товар. Но у клиента этот канал почти не использовался. Модераторы Яндекса отклоняли продвижение из-за неправильной генерации фида.\u003C\u002Fp\u003E\n\u003Cp\u003EМы помогли оптимизировать фид, чтобы начать рекламироваться на Маркете, и оперативно решали вопросы с модерацией. Также постоянно получали данные от клиента по продажам и повышали ставки на товары с более высокой маржой. Таким образом увеличили оборот «Мосплитки» по сантехнике.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EСейчас привлекаем из Маркета около 60% заявок. По стоимости они в два раза ниже, чем с Яндекс.Директа.\u003C\u002Fstrong\u003E\u003C\u002Fp\u003E\n\u003Cp\u003EПри этом мы пробовали использовать другие товарные площадки, но Яндекс.Маркет оказалась самой эффективной.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:c,section_title:"Создали дашборды для отслеживания эффективности",content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003EКлиент может видеть и сравнивать результаты нашей работы по разным каналам и за разные месяцы. Для этого мы разработали дашборды в Power BI. По ним также отслеживают эффективность своей работы специалисты и менеджер проекта.\u003C\u002Fp\u003E\n\u003Cp\u003EНа дашборде ниже воронка от посещения сайта до подтверждения заказа в корзине. По ней мы определяем, как работают разные каналы при заказах через сайт, и оптимизируем их благодаря этой статистике.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-674\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-900x521.png\" alt=\"\" width=\"900\" height=\"521\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-900x521.png 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-450x261.png 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-650x377.png 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-1300x753.png 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-768x445.png 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1.png 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-1200x695.png 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-660x382.png 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-1320x765.png 1320w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-414x240.png 414w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-828x480.png 828w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-604x350.png 604w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F7-1-1208x700.png 1208w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n\u003Cp\u003EДля Яндекс.Маркета сделали отдельный дашборд. На нем видна эффективность продвижения товаров и брендов и связь эффективности с ценовым диапазоном товаров и их категорий. А панель мониторинга предупреждает, если стоимость заявки по каким-то товарам слишком высокая.\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cimg class=\"alignnone size-medium wp-image-675\" src=\"http:\u002F\u002Fserenity.serenity-dev.ru\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-900x521.png\" alt=\"\" width=\"900\" height=\"521\" srcset=\"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-900x521.png 900w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-450x261.png 450w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-650x377.png 650w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-1300x753.png 1300w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-768x445.png 768w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8.png 1600w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-1200x695.png 1200w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-660x382.png 660w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-1320x765.png 1320w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-414x240.png 414w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-828x480.png 828w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-604x350.png 604w, https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002F8-1208x700.png 1208w\" sizes=\"(max-width: 900px) 100vw, 900px\" \u002F\u003E\u003C\u002Fp\u003E\n\u003Cp\u003E\u003Cstrong\u003EВсе эти действия уже принесли результат.\u003C\u002Fstrong\u003E Через инструменты Яндекса мы получаем 75% заявок и выполняем планы продаж клиента. Но в будущем планируем привлечь и другие инструменты, чтобы сделать показатели еще лучше. Например, использовать платное продвижение через Яндекс.Карты.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]}],tags:{case:r},term:p,read_also:[{title:aL,slug:aM,background:aN,type:r,type_slug:p},{title:br,slug:bs,background:bt,type:r,type_slug:p}],embed:g,meta_title:"Продвижение магазина «Мосплитка»: как снизить стоимость обращения в 2 раза — Статья — Serenity",meta_description:tV,meta_image:tU},"kak-my-sozdali-brend-ang":{title:gL,slug:gM,description:wT,background:{url:aht,sizes:{thumbnail:ahu,medium:ml,medium_large:ahv,large:wS,carousel:ahw,wide:gN,standart:ahx,"thumb-x2":ahy,case:ahz,case2x:ml,caseBig:ahA,caseBig2x:ahB,blog:ahC,blog2x:ahD}},author:{expert:{name:j,role:e,image:b},text:a},date:ahE,content:[{acf_fc_layout:c,section_title:a,content_repeater:[{block_subtitle:a,is_note:b,text_block:"\u003Cp\u003E\u003Cstrong\u003EО клиенте. \u003C\u002Fstrong\u003EКлиент помогает предпринимателям наладить их внутренние бизнес-процессы: проводит аудит работы сотрудников, привлекает дополнительные инвестиции в проект, разрабатывает стратегии выхода из кризиса.\u003C\u002Fp\u003E\n\u003Cp class=\" article_decoration_last\"\u003E\u003Cstrong\u003EО задаче. \u003C\u002Fstrong\u003EПоскольку у стартапа не было до конца сформированной платформы бренда, мы предложили клиенту начать работу с разработки нейминга, затем создать фирменный стиль и завершить разработкой сайта.\u003C\u002Fp\u003E\n\u003Cp\u003EСайт — \u003Ca href=\"http:\u002F\u002Fang-partner.com\u002F\"\u003Eang-partner.com\u003C\u002Fa\u003E.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:"Узнали о ценностях",is_note:b,text_block:"\u003Cp class=\"article_decoration_first\"\u003EЗаказчик рассказал, что хочет делать акцент на ценностях, которые позволяют совершенствовать бизнес. Среди них интеллект, знания, созидательность. Очень важно, чтобы ценности совпадали у обеих сторон и были направлены не на извлечение прибыли, а на развитие бизнеса.\u003C\u002Fp\u003E\n\u003Cp class=\" article_decoration_last\"\u003EТакже клиент рекомендовал нам обратить внимание на книгу «Атлант расправил плечи». В ней отражались принципы успешного и целеустремленного предпринимателя.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b},{block_subtitle:"Придумали имя",is_note:m,text_block:"\u003Cp class=\"article_decoration_first\"\u003EИскали короткое название. Мы выяснили, что в сфере консалтинга компании с короткими именами или аббревиатурами со смыслом пользуются большим доверием со стороны клиента.\u003C\u002Fp\u003E\n\u003Cp\u003EПомимо ценностей компании, которые заказчик хотел транслировать через название, он также набросал лист желаемых ассоциаций с его бизнесом: стабильность, партнерство, уверенность.\u003C\u002Fp\u003E\n\u003Cp class=\" article_decoration_last article_decoration_before\"\u003EВместе с командой придумали более 100 вариантов названий. Заказчику понравился вариант ANG. Мы заложили в него ассоциацию с термином «бизнес-ангел». Бизнес-ангелы — это инвесторы, поддерживающие бизнес и помогающие принимать управленческие решения.\u003C\u002Fp\u003E\n\u003Cp\u003EТакже аббревиатура ANG раскрывает ценности компании:\u003C\u002Fp\u003E\n\u003Cp class=\" article_decoration_last\"\u003EA — advanced — прогрессивный.\u003Cbr \u002F\u003E\nN — necessary — обязательный.\u003Cbr \u002F\u003E\nG — genius — гениальный.\u003C\u002Fp\u003E\n",note_counter:"\u003E 100",note:"названий придумали вместе с командой",expert:b},{block_subtitle:"Сделали логотип и фирменный стиль",is_note:b,text_block:"\u003Cp\u003EНа основе нейминга мы разработали несколько вариантов логотипа для ANG.\u003C\u002Fp\u003E\n",note_counter:a,note:a,expert:b}]},{acf_fc_layout:S,type:as,photos:[{ID:at$,id:at$,title:"анг-лого-1",filename:"ang-logo-1.jpg",url:aS,alt:a,author:u,description:a,caption:a,name:"ang-logo-1",date:aua,modified:aua,mime_type:K,type:v,icon:w,width:aT,height:V,sizes:{thumbnail:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002Fang-logo-1-300x300.jpg","thumbnail-width":h,"thumbnail-height":h,medium:aS,"medium-width":aT,"medium-height":V,medium_large:aS,"medium_large-width":aT,"medium_large-height":V,large:aS,"large-width":aT,"large-height":V,carousel:aS,"carousel-width":aT,"carousel-height":V,wide:aS,"wide-width":aT,"wide-height":V,standart:aS,"standart-width":aT,"standart-height":V,"thumb-x2":aS,"thumb-x2-width":aT,"thumb-x2-height":V,case:"https:\u002F\u002Fserenity.agency\u002Fadmin\u002Fwp-content\u002Fuploads\u002F2018\u002F12\u002Fang-logo-1-450x319.jpg","