# Локальный запуск send_morning_message.py (не коммитить с реальными ключами).
# Скопируйте в integrations/slack/secrets.env и: source integrations/slack/secrets.env
#
# GitHub Actions: те же переменные — в Settings → Secrets → Actions репозитория serenity.

SLACK_MORNING_BOT_TOKEN=xoxb-your-bot-token
SLACK_MORNING_CHANNEL_ID=C0123456789

SLACK_MORNING_LLM_API_KEY=sk-your-openai-key
# Опционально:
# SLACK_MORNING_LLM_MODEL=gpt-4o-mini
# SLACK_MORNING_LLM_BASE_URL=https://api.openai.com/v1

# Только для проверки fallback без LLM:
# SLACK_MORNING_FORCE_FALLBACK=1
