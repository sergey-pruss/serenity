  "mountId": "kontekst-synergy-mounted",
  "rootClass": "kontekst-synergy-root",
  "bodyHtml": "<div data-v-6f8a040c=\"\" style=\"z-index: 10\">\n    <div\n      data-v-56f85d51=\"\"\n      data-v-6f8a040c=\"\"\n      class=\"services-unified\"\n      style=\"-webkit-tap-highlight-color: transparent\"\n    >\n      <div\n        data-v-56f85d51=\"\"\n        class=\"block-padding block-padding_desktop\"\n        style=\"padding-top: 90px\"\n      ></div>\n      <div\n        data-v-56f85d51=\"\"\n        class=\"block-padding block-padding_tablet\"\n        style=\"padding-top: 68px\"\n      ></div>\n      <div\n        data-v-56f85d51=\"\"\n        class=\"block-padding block-padding_mobile\"\n        style=\"padding-top: 48px\"\n      ></div>\n      <section\n        data-v-56f85d51=\"\"\n        class=\"services-section services-section_main-structure isNewContent\"\n      >\n        <div data-v-56f85d51=\"\" class=\"services__text home-ledge\">\n          <h3 data-v-56f85d51=\"\" class=\"services__title kontekstnaya-page__section-heading\">Синергия с&nbsp;услугами</h3>\n        </div>\n        <div\n          data-v-56f85d51=\"\"\n          class=\"services__context-slider swiper-container swiper-container-horizontal swiper-container-free-mode\"\n        >\n          <div data-v-56f85d51=\"\" class=\"services__context-wrapper swiper-wrapper\">\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <a data-v-56f85d51=\"\" href=\"/kompleksnoye-prodvizheniye\" class=\"services__card-container services__card-container-img\"\n                    ><h3 data-v-56f85d51=\"\">Комплексное продвижение</h3>\n                    <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\n                      Доносим преимущества бренда до&nbsp;аудитории и&nbsp;увеличиваем конверсию через&nbsp;различные инструменты.\n                    </p>\n                    <div data-v-56f85d51=\"\" class=\"services__card-img-wr\">\n                      <img data-v-56f85d51=\"\" src=\"/_sa/img/storage__2MRra5DUPNo2hTBZKN6FwTih3CENW6iwFPPhefjx.png\" alt=\"\" loading=\"eager\" fetchpriority=\"high\" decoding=\"async\" class=\"services__card-img services__card-img_desc\" />\n                      <img data-v-56f85d51=\"\" src=\"/_sa/img/storage__22coyPtNpva5LAxcC6rng1WJa7laye9yojsNE8uQ.png\" alt=\"\" loading=\"eager\" decoding=\"async\" class=\"services__card-img services__card-img_tablet\" />\n                      <img data-v-56f85d51=\"\" src=\"/_sa/img/storage__IQrET6dOZ5lBMvXXLrxjGEJaUVN5FGyWgbi7sV2k.png\" alt=\"\" loading=\"eager\" decoding=\"async\" class=\"services__card-img services__card-img_mobile\" />\n                    </div></a\n                  >\n                </div>\n              </div>\n            </div>\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a data-v-56f85d51=\"\" href=\"/services/content\" class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">Контент-маркетинг</h3>\n                      <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\n                        Исследуем нишу компании и&nbsp;формируем вокруг бренда аудиторию, которая рекомендует вас другим.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a data-v-56f85d51=\"\" href=\"/naming\" class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">Фирменный стиль</h3>\n                      <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\n                        Разрабатываем логотип и&nbsp;элементы фирменного стиля, которые будут привлекать внимание и&nbsp;нравиться вашей аудитории.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a data-v-56f85d51=\"\" href=\"/services/video\" class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">Фото и&nbsp;видео</h3>\n                      <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\n                        Создаем цепляющие видео и&nbsp;фото для&nbsp;решения маркетинговых задач. Улучшаем репутацию бренда.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          <div data-v-56f85d51=\"\">\n            <button\n              data-v-56f85d51=\"\"\n              type=\"button\"\n              class=\"swiper-button-next\"\n              aria-label=\"Next slide\"\n            >\n              <svg\n                width=\"12\"\n                height=\"20\"\n                viewBox=\"0 0 12 20\"\n                fill=\"none\"\n                xmlns=\"http://www.w3.org/2000/svg\"\n              >\n                <path\n                  d=\"M1.39844 0.900391L10.5908 10.0928L1.39844 19.2852\"\n                  stroke=\"white\"\n                  stroke-linecap=\"round\"\n                  stroke-linejoin=\"round\"\n                ></path>\n              </svg>\n            </button>\n            <button\n              data-v-56f85d51=\"\"\n              type=\"button\"\n              class=\"swiper-button-prev\"\n              style=\"transform: rotate(180deg)\"\n              aria-label=\"Previous slide\"\n            >\n              <svg\n                width=\"12\"\n                height=\"20\"\n                viewBox=\"0 0 12 20\"\n                fill=\"none\"\n                xmlns=\"http://www.w3.org/2000/svg\"\n              >\n                <path\n                  d=\"M1.39844 0.900391L10.5908 10.0928L1.39844 19.2852\"\n                  stroke=\"white\"\n                  stroke-linecap=\"round\"\n                  stroke-linejoin=\"round\"\n                ></path>\n              </svg>\n            </button>\n          </div>\n        </div>\n      </section>\n    </div>\n  </div>"
}
