{
  "mountId": "kontekst-synergy-mounted",
  "rootClass": "kontekst-synergy-root",
  "bodyHtml": "<div data-v-6f8a040c=\"\" style=\"z-index: 10\">\n    <div\n      data-v-56f85d51=\"\"\n      data-v-6f8a040c=\"\"\n      class=\"services-unified\"\n      style=\"-webkit-tap-highlight-color: transparent\"\n    >\n      <div\n        data-v-56f85d51=\"\"\n        class=\"block-padding block-padding_desktop\"\n        style=\"padding-top: 90px\"\n      ></div>\n      <div\n        data-v-56f85d51=\"\"\n        class=\"block-padding block-padding_tablet\"\n        style=\"padding-top: 68px\"\n      ></div>\n      <div\n        data-v-56f85d51=\"\"\n        class=\"block-padding block-padding_mobile\"\n        style=\"padding-top: 48px\"\n      ></div>\n      <section\n        data-v-56f85d51=\"\"\n        class=\"services-section services-section_main-structure isNewContent\"\n      >\n        <div data-v-56f85d51=\"\" class=\"services__text home-ledge\">\n          <h3 data-v-56f85d51=\"\" class=\"services__title kontekstnaya-page__section-heading\">Синергия с услугами</h3>\n        </div>\n        <div\n          data-v-56f85d51=\"\"\n          class=\"services__context-slider swiper-container swiper-container-horizontal swiper-container-free-mode\"\n        >\n          <div data-v-56f85d51=\"\" class=\"services__context-wrapper swiper-wrapper\">\n            <div\n              data-v-56f85d51=\"\"\n              class=\"services__slide swiper-slide\"\n              style=\"margin-right: 30px\"\n            >\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <a\n                    data-v-56f85d51=\"\"\n                    href=\"/kompleksnoye-prodvizheniye\"\n                    class=\"services__card-container services__card-container-img\"\n                    ><h3 data-v-56f85d51=\"\">Комплексное продвижение</h3>\n                    <p\n                      data-v-56f85d51=\"\"\n                      class=\"services__card-description services__card-description-animation\"\n                    >\n                      Доносим преимущества бренда до аудитории и увеличиваем конверсию через\n                      различные инструменты.\n                    </p>\n                    <div data-v-56f85d51=\"\" class=\"services__card-img-wr\">\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__2MRra5DUPNo2hTBZKN6FwTih3CENW6iwFPPhefjx.png\"\n                        alt=\"\"\n                        loading=\"eager\"\n                        fetchpriority=\"high\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_desc\"\n                      />\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__22coyPtNpva5LAxcC6rng1WJa7laye9yojsNE8uQ.png\"\n                        alt=\"\"\n                        loading=\"eager\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_tablet\"\n                      />\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__IQrET6dOZ5lBMvXXLrxjGEJaUVN5FGyWgbi7sV2k.png\"\n                        alt=\"\"\n                        loading=\"eager\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_mobile\"\n                      />\n                    </div>\n                  </a>\n                </div>\n              </div>\n            </div>\n            <div\n              data-v-56f85d51=\"\"\n              class=\"services__slide swiper-slide\"\n              style=\"margin-right: 30px\"\n            >\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a\n                      data-v-56f85d51=\"\"\n                      href=\"/services/seo\"\n                      target=\"_blank\"\n                      class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">SEO</h3>\n                      <p\n                        data-v-56f85d51=\"\"\n                        class=\"services__card-description services__card-description-animation\"\n                      >\n                        Оптимизируем сайт и выводим его в топ по релевантным запросам.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a\n                      data-v-56f85d51=\"\"\n                      href=\"/targeting\"\n                      class=\"services__card-container services__card-container-text\"\n                      style=\"-webkit-tap-highlight-color: transparent\"\n                      ><h3 data-v-56f85d51=\"\">Таргетированная реклама</h3>\n                      <p\n                        data-v-56f85d51=\"\"\n                        class=\"services__card-description services__card-description-animation\"\n                      >\n                        Увеличиваем продажи с помощью соцсетей.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div\n              data-v-56f85d51=\"\"\n              class=\"services__slide swiper-slide\"\n              style=\"margin-right: 30px\"\n            >\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a\n                      data-v-56f85d51=\"\"\n                      href=\"/smm_marketing\"\n                      target=\"_blank\"\n                      class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">Комплексный SMM</h3>\n                      <p\n                        data-v-56f85d51=\"\"\n                        class=\"services__card-description services__card-description-animation\"\n                      >\n                        Создаем сильный бренд, регулярно общаемся с аудиторией и отслеживаем ее путь\n                        от поста до покупки.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a\n                      data-v-56f85d51=\"\"\n                      href=\"/services/content\"\n                      target=\"_blank\"\n                      class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">Контент-маркетинг</h3>\n                      <p\n                        data-v-56f85d51=\"\"\n                        class=\"services__card-description services__card-description-animation\"\n                      >\n                        Исследуем нишу компании и формируем вокруг бренда аудиторию, которая\n                        рекомендует вас другим.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div\n              data-v-56f85d51=\"\"\n              class=\"services__slide swiper-slide\"\n              style=\"margin-right: 30px\"\n            >\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a\n                      data-v-56f85d51=\"\"\n                      href=\"/korporativnyj_sajt\"\n                      class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">Сайт</h3>\n                      <p\n                        data-v-56f85d51=\"\"\n                        class=\"services__card-description services__card-description-animation\"\n                      >\n                        Создаем сайты, которые раскрывают бренд и налаживают контакт с покупателями.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a\n                      data-v-56f85d51=\"\"\n                      href=\"/pr\"\n                      target=\"_blank\"\n                      class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">PR-продвижение</h3>\n                      <p\n                        data-v-56f85d51=\"\"\n                        class=\"services__card-description services__card-description-animation\"\n                      >\n                        Находим СМИ, которые читает ваша аудитория, продумываем инфоповоды.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div\n              data-v-56f85d51=\"\"\n              class=\"services__slide swiper-slide\"\n              style=\"margin-right: 30px\"\n            >\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a\n                      data-v-56f85d51=\"\"\n                      href=\"/business-analytics\"\n                      target=\"_blank\"\n                      class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">Бизнес-аналитика</h3>\n                      <p\n                        data-v-56f85d51=\"\"\n                        class=\"services__card-description services__card-description-animation\"\n                      >\n                        Оцениваем эффективность рекламы и рентабельность бизнеса.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a\n                      data-v-56f85d51=\"\"\n                      href=\"/services/salesmarketing\"\n                      target=\"_blank\"\n                      class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">Маркетинг продаж</h3>\n                      <p\n                        data-v-56f85d51=\"\"\n                        class=\"services__card-description services__card-description-animation\"\n                      >\n                        Выстраиваем работу с заявками и обучаем работать с входным трафиком.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div\n              data-v-56f85d51=\"\"\n              class=\"services__slide swiper-slide\"\n              style=\"margin-right: 30px\"\n            >\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a\n                      data-v-56f85d51=\"\"\n                      href=\"/end-to-end-analytics\"\n                      target=\"_blank\"\n                      class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">Сквозная аналитика</h3>\n                      <p\n                        data-v-56f85d51=\"\"\n                        class=\"services__card-description services__card-description-animation\"\n                      >\n                        Оптимизируем маркетинговые расходы и повышаем эффективность.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\n                    <a\n                      data-v-56f85d51=\"\"\n                      href=\"/influence-marketing\"\n                      target=\"_blank\"\n                      class=\"services__card-container services__card-container-text\"\n                      ><h3 data-v-56f85d51=\"\">Influence-маркетинг</h3>\n                      <p\n                        data-v-56f85d51=\"\"\n                        class=\"services__card-description services__card-description-animation\"\n                      >\n                        Подбираем лидеров мнений для партнерства и взаимодействуем.\n                      </p></a\n                    >\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          <div data-v-56f85d51=\"\">\n            <button\n              data-v-56f85d51=\"\"\n              type=\"button\"\n              class=\"swiper-button-next\"\n              aria-label=\"Next slide\"\n            >\n              <svg\n                width=\"12\"\n                height=\"20\"\n                viewBox=\"0 0 12 20\"\n                fill=\"none\"\n                xmlns=\"http://www.w3.org/2000/svg\"\n              >\n                <path\n                  d=\"M1.39844 0.900391L10.5908 10.0928L1.39844 19.2852\"\n                  stroke=\"white\"\n                  stroke-linecap=\"round\"\n                  stroke-linejoin=\"round\"\n                ></path>\n              </svg>\n            </button>\n            <button\n              data-v-56f85d51=\"\"\n              type=\"button\"\n              class=\"swiper-button-prev\"\n              style=\"transform: rotate(180deg)\"\n              aria-label=\"Previous slide\"\n            >\n              <svg\n                width=\"12\"\n                height=\"20\"\n                viewBox=\"0 0 12 20\"\n                fill=\"none\"\n                xmlns=\"http://www.w3.org/2000/svg\"\n              >\n                <path\n                  d=\"M1.39844 0.900391L10.5908 10.0928L1.39844 19.2852\"\n                  stroke=\"white\"\n                  stroke-linecap=\"round\"\n                  stroke-linejoin=\"round\"\n                ></path>\n              </svg>\n            </button>\n          </div>\n        </div>\n      </section>\n    </div>\n  </div>"
}
