  "mountId": "kontekst-synergy-mounted",
  "rootClass": "kontekst-synergy-root",
  "bodyHtml": "<div data-v-6f8a040c=\"\" style=\"z-index: 10\">\n    <div\n      data-v-56f85d51=\"\"\n      data-v-6f8a040c=\"\"\n      class=\"services-unified\"\n      style=\"-webkit-tap-highlight-color: transparent\"\n    >\n      <div\n        data-v-56f85d51=\"\"\n        class=\"block-padding block-padding_desktop\"\n        style=\"padding-top: 90px\"\n      ></div>\n      <div\n        data-v-56f85d51=\"\"\n        class=\"block-padding block-padding_tablet\"\n        style=\"padding-top: 68px\"\n      ></div>\n      <div\n        data-v-56f85d51=\"\"\n        class=\"block-padding block-padding_mobile\"\n        style=\"padding-top: 48px\"\n      ></div>\n      <section\n        data-v-56f85d51=\"\"\n        class=\"services-section services-section_main-structure isNewContent\"\n      >\n        <div data-v-56f85d51=\"\" class=\"services__text home-ledge\">\n          <h3 data-v-56f85d51=\"\" class=\"services__title kontekstnaya-page__section-heading\">Синергия с&nbsp;услугами</h3>\n        </div>\n        <div\n          data-v-56f85d51=\"\"\n          class=\"services__context-slider swiper-container\"\n        >\n          <div data-v-56f85d51=\"\" class=\"services__context-wrapper swiper-wrapper\">\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <a\n                    data-v-56f85d51=\"\"\n                    href=\"/strategy\"\n                    class=\"services__card-container services__card-container-img\"\n                    ><h3 data-v-56f85d51=\"\">Маркетинговая стратегия</h3>\n                    <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\n                      Долгосрочно развиваем бизнес через&nbsp;планы по&nbsp;улучшению продаж и&nbsp;продвижению.\n                    </p>\n                    <div data-v-56f85d51=\"\" class=\"services__card-img-wr\">\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__MKaVjKprI7xFUz4Q8FJ01vvk7RcB68XCaCp8baXz.png\"\n                        alt=\"\"\n                        loading=\"eager\"\n                        fetchpriority=\"high\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_desc\"\n                      />\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__ZXFgZKfbkndpcWQGfZlk1CvhzN3QjcBi0EmPOuC2.png\"\n                        alt=\"\"\n                        loading=\"eager\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_tablet\"\n                      />\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__2LzLQ7ln7sRSWU637UrKFdWAyZfSF1UpVWfo71FS.png\"\n                        alt=\"\"\n                        loading=\"eager\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_mobile\"\n                      />\n                    </div>\n                  </a>\n                </div>\n              </div>\n            </div>\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <a\n                    data-v-56f85d51=\"\"\n                    href=\"/smm_marketing\"\n                    class=\"services__card-container services__card-container-img\"\n                    ><h3 data-v-56f85d51=\"\">Комплексный SMM</h3>\n                    <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\n                      Налаживаем коммуникацию с&nbsp;аудиторией в&nbsp;соцсетях.\n                    </p>\n                    <div data-v-56f85d51=\"\" class=\"services__card-img-wr\">\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__voAqLMMIyxzucaUkl7wTUsZRBWNjb8jwlq5cWkZ3.png\"\n                        alt=\"\"\n                        loading=\"lazy\"\n                        fetchpriority=\"low\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_desc\"\n                      />\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__LNwZktZ3RLL6Hvieyd9JhTIE3XnoEkwCGfYF63tt.png\"\n                        alt=\"\"\n                        loading=\"lazy\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_tablet\"\n                      />\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__VKRVQGAKctnl5ZSMIRM41hZGTxfIqswrBwGKds2u.png\"\n                        alt=\"\"\n                        loading=\"lazy\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_mobile\"\n                      />\n                    </div>\n                  </a>\n                </div>\n              </div>\n            </div>\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <a\n                    data-v-56f85d51=\"\"\n                    href=\"/content\"\n                    class=\"services__card-container services__card-container-img\"\n                    ><h3 data-v-56f85d51=\"\">Контент-маркетинг</h3>\n                    <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\n                      Исследуем нишу компании и&nbsp;формируем вокруг бренда аудиторию, которая рекомендует вас другим.\n                    </p>\n                    <div data-v-56f85d51=\"\" class=\"services__card-img-wr\">\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__TB1trsUUPmGZAadxaOvxBo8t8UTCqi8CwM4wcmcj.png\"\n                        alt=\"\"\n                        loading=\"lazy\"\n                        fetchpriority=\"low\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_desc\"\n                      />\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__67oNSz7QQE2V9bh2TV2LmB8ffbw0Ib6RFkdQYfRV.png\"\n                        alt=\"\"\n                        loading=\"lazy\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_tablet\"\n                      />\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__AvLcsH5lJJVfH3IjaMBjxHZMGPQQ9eQM3Nf8RPlt.png\"\n                        alt=\"\"\n                        loading=\"lazy\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_mobile\"\n                      />\n                    </div>\n                  </a>\n                </div>\n              </div>\n            </div>\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\n              <div data-v-56f85d51=\"\">\n                <div data-v-56f85d51=\"\" class=\"services__card\">\n                  <a\n                    data-v-56f85d51=\"\"\n                    href=\"/services/production\"\n                    class=\"services__card-container services__card-container-img\"\n                    ><h3 data-v-56f85d51=\"\">Сайт</h3>\n                    <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\n                      Создаем сайты, помогающие раскрыть бренд, влюбить в&nbsp;себя клиентов, увеличить продажи продуктов и&nbsp;услуг.\n                    </p>\n                    <div data-v-56f85d51=\"\" class=\"services__card-img-wr\">\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__x3xF73XQ66oC2qMVCxwLCu0idoI1XKsx2v5cBuzI.png\"\n                        alt=\"\"\n                        loading=\"lazy\"\n                        fetchpriority=\"low\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_desc\"\n                      />\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__xbx0NZb5a1hOHC0hEgRB7KxqK4lbFFOEz0NTncb7.png\"\n                        alt=\"\"\n                        loading=\"lazy\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_tablet\"\n                      />\n                      <img\n                        data-v-56f85d51=\"\"\n                        src=\"/_sa/img/storage__rrzrpvBOupLNBuOm1ieD4VUpMVcDp5sPgl6pkFIz.png\"\n                        alt=\"\"\n                        loading=\"lazy\"\n                        decoding=\"async\"\n                        class=\"services__card-img services__card-img_mobile\"\n                      />\n                    </div>\n                  </a>\n                </div>\n              </div>\n            </div>\n          </div>\n          <div data-v-56f85d51=\"\">\n            <button\n              data-v-56f85d51=\"\"\n              type=\"button\"\n              class=\"swiper-button-next\"\n              aria-label=\"Next slide\"\n            >\n              <svg\n                width=\"12\"\n                height=\"20\"\n                viewBox=\"0 0 12 20\"\n                fill=\"none\"\n                xmlns=\"http://www.w3.org/2000/svg\"\n              >\n                <path\n                  d=\"M1.39844 0.900391L10.5908 10.0928L1.39844 19.2852\"\n                  stroke=\"white\"\n                  stroke-linecap=\"round\"\n                  stroke-linejoin=\"round\"\n                ></path>\n              </svg>\n            </button>\n            <button\n              data-v-56f85d51=\"\"\n              type=\"button\"\n              class=\"swiper-button-prev\"\n              style=\"transform: rotate(180deg)\"\n              aria-label=\"Previous slide\"\n            >\n              <svg\n                width=\"12\"\n                height=\"20\"\n                viewBox=\"0 0 12 20\"\n                fill=\"none\"\n                xmlns=\"http://www.w3.org/2000/svg\"\n              >\n                <path\n                  d=\"M1.39844 0.900391L10.5908 10.0928L1.39844 19.2852\"\n                  stroke=\"white\"\n                  stroke-linecap=\"round\"\n                  stroke-linejoin=\"round\"\n                ></path>\n              </svg>\n            </button>\n          </div>\n        </div>\n      </section>\n    </div>\n  </div>"
}
