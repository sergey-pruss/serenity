  "mountId": "kontekst-synergy-mounted",
  "rootClass": "kontekst-synergy-root",
  "bodyHtml": "<div data-v-6f8a040c=\"\" style=\"z-index: 10\">\r\n    <div\r\n      data-v-56f85d51=\"\"\r\n      data-v-6f8a040c=\"\"\r\n      class=\"services-unified\"\r\n      style=\"-webkit-tap-highlight-color: transparent\"\r\n    >\r\n      <div\r\n        data-v-56f85d51=\"\"\r\n        class=\"block-padding block-padding_desktop\"\r\n        style=\"padding-top: 90px\"\r\n      ></div>\r\n      <div\r\n        data-v-56f85d51=\"\"\r\n        class=\"block-padding block-padding_tablet\"\r\n        style=\"padding-top: 68px\"\r\n      ></div>\r\n      <div\r\n        data-v-56f85d51=\"\"\r\n        class=\"block-padding block-padding_mobile\"\r\n        style=\"padding-top: 48px\"\r\n      ></div>\r\n      <section\r\n        data-v-56f85d51=\"\"\r\n        class=\"services-section services-section_main-structure isNewContent\"\r\n      >\r\n        <div data-v-56f85d51=\"\" class=\"services__text home-ledge\">\r\n          <h3 data-v-56f85d51=\"\" class=\"services__title kontekstnaya-page__section-heading\">Синергия с&nbsp;услугами</h3>\r\n        </div>\r\n        <div\r\n          data-v-56f85d51=\"\"\r\n          class=\"services__context-slider swiper-container\"\r\n        >\r\n          <div data-v-56f85d51=\"\" class=\"services__context-wrapper swiper-wrapper\">\r\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\r\n              <div data-v-56f85d51=\"\">\r\n                <div data-v-56f85d51=\"\" class=\"services__card\">\r\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\r\n                    <a\r\n                      data-v-56f85d51=\"\"\r\n                      href=\"/seo\"\r\n                      class=\"services__card-container services__card-container-text\"\r\n                      style=\"-webkit-tap-highlight-color: transparent\"\r\n                      ><h3 data-v-56f85d51=\"\">SEO</h3>\r\n                      <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\r\n                        Оптимизируем сайт и&nbsp;выводим его в&nbsp;топ по&nbsp;релевантным запросам.\r\n                      </p></a>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n              <div data-v-56f85d51=\"\">\r\n                <div data-v-56f85d51=\"\" class=\"services__card\">\r\n                  <div data-v-56f85d51=\"\" class=\"services__card-ccccc\">\r\n                    <a\r\n                      data-v-56f85d51=\"\"\r\n                      href=\"/kontekstnaya_reklama\"\r\n                      class=\"services__card-container services__card-container-text\"\r\n                      style=\"-webkit-tap-highlight-color: transparent\"\r\n                      ><h3 data-v-56f85d51=\"\">Контекстная реклама</h3>\r\n                      <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\r\n                        Увеличиваем трафик на&nbsp;сайт и&nbsp;доводим аудиторию до&nbsp;покупки.\r\n                      </p></a>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\r\n              <div data-v-56f85d51=\"\">\r\n                <div data-v-56f85d51=\"\" class=\"services__card\">\r\n                  <a\r\n                    data-v-56f85d51=\"\"\r\n                    href=\"/strategy\"\r\n                    class=\"services__card-container services__card-container-img\"\r\n                    ><h3 data-v-56f85d51=\"\">Маркетинговая стратегия</h3>\r\n                    <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\r\n                      Долгосрочно развиваем бизнес через&nbsp;планы по&nbsp;улучшению продаж и&nbsp;продвижению.\r\n                    </p>\r\n                    <div data-v-56f85d51=\"\" class=\"services__card-img-wr\">\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__MKaVjKprI7xFUz4Q8FJ01vvk7RcB68XCaCp8baXz.png\"\r\n                        alt=\"\"\r\n                        loading=\"eager\"\r\n                        fetchpriority=\"high\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_desc\"\r\n                      />\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__ZXFgZKfbkndpcWQGfZlk1CvhzN3QjcBi0EmPOuC2.png\"\r\n                        alt=\"\"\r\n                        loading=\"eager\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_tablet\"\r\n                      />\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__2LzLQ7ln7sRSWU637UrKFdWAyZfSF1UpVWfo71FS.png\"\r\n                        alt=\"\"\r\n                        loading=\"eager\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_mobile\"\r\n                      />\r\n                    </div>\r\n                  </a>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\r\n              <div data-v-56f85d51=\"\">\r\n                <div data-v-56f85d51=\"\" class=\"services__card\">\r\n                  <a\r\n                    data-v-56f85d51=\"\"\r\n                    href=\"/smm_marketing\"\r\n                    class=\"services__card-container services__card-container-img\"\r\n                    ><h3 data-v-56f85d51=\"\">Комплексный SMM</h3>\r\n                    <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\r\n                      Налаживаем коммуникацию с&nbsp;аудиторией в&nbsp;соцсетях.\r\n                    </p>\r\n                    <div data-v-56f85d51=\"\" class=\"services__card-img-wr\">\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__voAqLMMIyxzucaUkl7wTUsZRBWNjb8jwlq5cWkZ3.png\"\r\n                        alt=\"\"\r\n                        loading=\"lazy\"\r\n                        fetchpriority=\"low\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_desc\"\r\n                      />\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__LNwZktZ3RLL6Hvieyd9JhTIE3XnoEkwCGfYF63tt.png\"\r\n                        alt=\"\"\r\n                        loading=\"lazy\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_tablet\"\r\n                      />\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__VKRVQGAKctnl5ZSMIRM41hZGTxfIqswrBwGKds2u.png\"\r\n                        alt=\"\"\r\n                        loading=\"lazy\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_mobile\"\r\n                      />\r\n                    </div>\r\n                  </a>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\r\n              <div data-v-56f85d51=\"\">\r\n                <div data-v-56f85d51=\"\" class=\"services__card\">\r\n                  <a\r\n                    data-v-56f85d51=\"\"\r\n                    href=\"/content\"\r\n                    class=\"services__card-container services__card-container-img\"\r\n                    ><h3 data-v-56f85d51=\"\">Контент-маркетинг</h3>\r\n                    <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\r\n                      Исследуем нишу компании и&nbsp;формируем вокруг бренда аудиторию, которая рекомендует вас другим.\r\n                    </p>\r\n                    <div data-v-56f85d51=\"\" class=\"services__card-img-wr\">\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__TB1trsUUPmGZAadxaOvxBo8t8UTCqi8CwM4wcmcj.png\"\r\n                        alt=\"\"\r\n                        loading=\"lazy\"\r\n                        fetchpriority=\"low\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_desc\"\r\n                      />\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__67oNSz7QQE2V9bh2TV2LmB8ffbw0Ib6RFkdQYfRV.png\"\r\n                        alt=\"\"\r\n                        loading=\"lazy\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_tablet\"\r\n                      />\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__AvLcsH5lJJVfH3IjaMBjxHZMGPQQ9eQM3Nf8RPlt.png\"\r\n                        alt=\"\"\r\n                        loading=\"lazy\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_mobile\"\r\n                      />\r\n                    </div>\r\n                  </a>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div data-v-56f85d51=\"\" class=\"services__slide swiper-slide\" style=\"margin-right: 30px\">\r\n              <div data-v-56f85d51=\"\">\r\n                <div data-v-56f85d51=\"\" class=\"services__card\">\r\n                  <a\r\n                    data-v-56f85d51=\"\"\r\n                    href=\"/services/production\"\r\n                    class=\"services__card-container services__card-container-img\"\r\n                    ><h3 data-v-56f85d51=\"\">Сайт</h3>\r\n                    <p data-v-56f85d51=\"\" class=\"services__card-description services__card-description-animation\">\r\n                      Создаем сайты, помогающие раскрыть бренд, влюбить в&nbsp;себя клиентов, увеличить продажи продуктов и&nbsp;услуг.\r\n                    </p>\r\n                    <div data-v-56f85d51=\"\" class=\"services__card-img-wr\">\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__x3xF73XQ66oC2qMVCxwLCu0idoI1XKsx2v5cBuzI.png\"\r\n                        alt=\"\"\r\n                        loading=\"lazy\"\r\n                        fetchpriority=\"low\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_desc\"\r\n                      />\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__xbx0NZb5a1hOHC0hEgRB7KxqK4lbFFOEz0NTncb7.png\"\r\n                        alt=\"\"\r\n                        loading=\"lazy\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_tablet\"\r\n                      />\r\n                      <img\r\n                        data-v-56f85d51=\"\"\r\n                        src=\"/_sa/img/storage__rrzrpvBOupLNBuOm1ieD4VUpMVcDp5sPgl6pkFIz.png\"\r\n                        alt=\"\"\r\n                        loading=\"lazy\"\r\n                        decoding=\"async\"\r\n                        class=\"services__card-img services__card-img_mobile\"\r\n                      />\r\n                    </div>\r\n                  </a>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div data-v-56f85d51=\"\">\r\n            <button\r\n              data-v-56f85d51=\"\"\r\n              type=\"button\"\r\n              class=\"swiper-button-next\"\r\n              aria-label=\"Next slide\"\r\n            >\r\n              <svg\r\n                width=\"12\"\r\n                height=\"20\"\r\n                viewBox=\"0 0 12 20\"\r\n                fill=\"none\"\r\n                xmlns=\"http://www.w3.org/2000/svg\"\r\n              >\r\n                <path\r\n                  d=\"M1.39844 0.900391L10.5908 10.0928L1.39844 19.2852\"\r\n                  stroke=\"white\"\r\n                  stroke-linecap=\"round\"\r\n                  stroke-linejoin=\"round\"\r\n                ></path>\r\n              </svg>\r\n            </button>\r\n            <button\r\n              data-v-56f85d51=\"\"\r\n              type=\"button\"\r\n              class=\"swiper-button-prev\"\r\n              style=\"transform: rotate(180deg)\"\r\n              aria-label=\"Previous slide\"\r\n            >\r\n              <svg\r\n                width=\"12\"\r\n                height=\"20\"\r\n                viewBox=\"0 0 12 20\"\r\n                fill=\"none\"\r\n                xmlns=\"http://www.w3.org/2000/svg\"\r\n              >\r\n                <path\r\n                  d=\"M1.39844 0.900391L10.5908 10.0928L1.39844 19.2852\"\r\n                  stroke=\"white\"\r\n                  stroke-linecap=\"round\"\r\n                  stroke-linejoin=\"round\"\r\n                ></path>\r\n              </svg>\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </section>\r\n    </div>\r\n  </div>"
