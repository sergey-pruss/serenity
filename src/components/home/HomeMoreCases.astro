---
import { homeMoreCaseSlides } from "../../data/home-more-cases";
---
<section class="home-more-case-wr" aria-labelledby="home-cases-title">
  <div class="home-page__container">
    <div class="home-cases-block__header">
      <h2 id="home-cases-title" class="home-cases-block__header-title">Кейсы</h2>
      <p class="home-cases-block__header-subtitle">
        В основе работы нашего маркетингового агентства — подход брендформанса: с помощью синергии брендинга и
        перформанса добиваемся крутых результатов для наших клиентов.
      </p>
    </div>

    <div class="home-cases-rail" tabindex="0">
      <div class="home-cases-track">
        {
          homeMoreCaseSlides.map((s) => (
            <article class="home-cases-slide" style={`background-image:url('${s.image}')`}>
              <a
                class="home-cases-slide__link"
                href={s.href}
                target={s.external ? "_blank" : undefined}
                rel={s.external ? "noopener noreferrer" : undefined}
              >
                <p class:list={["home-cases-slide__text", s.textBlack && "home-cases-slide__text--black"]}>{s.text}</p>
              </a>
            </article>
          ))
        }
        <article class="home-cases-slide home-cases-slide--more">
          <a class="home-cases-slide__link" href="/case/all">
            <span class="home-cases-more-link">Смотреть больше кейсов</span>
          </a>
        </article>
      </div>
    </div>
  </div>
</section>
