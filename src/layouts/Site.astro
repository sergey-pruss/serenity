---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Serenity — маркетинговое агентство (статическая версия в разработке)." } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={canonical.href} />
  </head>
  <body>
    <a href="#main" class="skip-link">К содержанию</a>
    <header class="site-header">
      <strong class="logo">Serenity</strong>
      <nav aria-label="Основное меню">
        <a href="/case/all">Кейсы</a>
        <a href="/services">Услуги</a>
        <a href="/about">Агентство</a>
        <a href="/blog">Блог</a>
        <a href="/career/vacancy">Вакансии</a>
        <a href="/contacts">Контакты</a>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #0f0f12;
    --fg: #f4f4f5;
    --muted: #a1a1aa;
    --accent: #ac9eff;
    --border: #27272a;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    min-height: 100vh;
    font-family:
      system-ui,
      -apple-system,
      "Segoe UI",
      Roboto,
      Ubuntu,
      Cantarell,
      sans-serif;
    background: var(--bg);
    color: var(--fg);
    line-height: 1.5;
  }
  .skip-link {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .skip-link:focus {
    left: 16px;
    top: 16px;
    width: auto;
    height: auto;
    padding: 8px 12px;
    background: var(--accent);
    color: #0f0f12;
    border-radius: 6px;
    z-index: 100;
  }
  .site-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px 20px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
  }
  .logo {
    letter-spacing: 0.04em;
  }
  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 18px;
  }
  nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
  }
  nav a:hover {
    color: var(--accent);
  }
  main {
    max-width: 52rem;
    margin: 0 auto;
    padding: 32px 20px 64px;
  }
  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 600;
    margin: 0 0 12px;
  }
  .lead {
    color: var(--muted);
    margin: 0 0 24px;
  }
  .note {
    padding: 14px 16px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: rgba(172, 158, 255, 0.06);
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
