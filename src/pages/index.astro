---
import { loadPublishHomeDocument } from "../lib/load-publish-home.ts";
import Home from "../layouts/Home.astro";
import HomePage from "../components/home/HomePage.astro";

const mirrorDoc = loadPublishHomeDocument();
---
{
  mirrorDoc ? (
    <Fragment set:html={mirrorDoc} />
  ) : (
    <Home title="Serenity — маркетинговое агентство">
      <HomePage />
    </Home>
  )
}
